gationContext.getElementById(\"Eth3IPV4AddrAwsRow\");\nvar g=tabNavigationContext.getElementById(\"Eth3IPV4AddrMaskAwsRow\");if(f==\"1\"){if(h){a.style.display=\"none\";d.style.display=\"none\";if(c){c.style.display=\"\"}if(b){b.style.display=\"\"}if(i){i.style.display=\"\"\n}if(g){g.style.display=\"\"}}else{a.style.display=\"\";d.style.display=\"\";if(c){c.style.display=\"none\"}if(b){b.style.display=\"none\"}if(i){i.style.display=\"none\"}if(g){g.style.display=\"none\"}}if(e){e.style.display=\"\"\n}}else{a.style.display=\"none\";d.style.display=\"none\";if(e){e.style.display=\"none\"}if(c){c.style.display=\"none\"}if(b){b.style.display=\"none\"}if(i){i.style.display=\"none\"}if(g){g.style.display=\"none\"}}}function configureMediaNextHopIPVisibility(o){var g=tabNavigationContext.getElementById(\"defaultMapping-Hidden\");\nvar q=tabNavigationContext.getElementById(\"configureEth1IF-Field\");var p=tabNavigationContext.getElementById(\"configureEth2IF-Field\");var l=tabNavigationContext.getElementById(\"configureEth3IF-Field\");\nvar a=tabNavigationContext.getElementById(\"configureEth4IF-Field\");var d=tabNavigationContext.getElementById(\"eth1Mapped-Hidden\");var r=tabNavigationContext.getElementById(\"eth2Mapped-Hidden\");var k=tabNavigationContext.getElementById(\"eth3Mapped-Hidden\");\nvar b=tabNavigationContext.getElementById(\"eth4Mapped-Hidden\");var n=o.elements.length;for(var j=0;j<n;j++){if(o.elements[j].name==\"applicationIPV4Address\"){if(d.value==\"1\"){var m=tabNavigationContext.getElementById(\"applicationIPV4Address-Field\");\nif(!isVSBCE()||(m.value.indexOf(\"169.254\")!=0&&(g.value==\"0\"||(q&&q.value==\"1\")))){tabNavigationContext.getElementById(\"eth1NextHopRow\").style.display=\"\"}else{tabNavigationContext.getElementById(\"eth1NextHopRow\").style.display=\"none\"\n}}}else{if(o.elements[j].name==\"eth2IPV4Address\"){if(r.value==\"1\"){var h=tabNavigationContext.getElementById(\"eth2IPV4Address-Field\");if(!isVSBCE()||(h.value.indexOf(\"169.254\