            "text": "/* \n    Document   : accordion\n    Created on : Sep 24, 2009, 10:29:50 AM\n    Author     : prakashc\n    Description:\n        Purpose of the stylesheet follows.\n*/\n\n/* Entire pane */\n\n.AccordionPane {\n    background-color: #fcfffa;\n    float:left;\n    height:100%;\n    width:100%;\n}\n.AccordionPane .dhtmlgoodies_panel{\n    margin-left:1px;\n    margin-right:1px;\n}\n.AccordionPane .panelContent{\n    font-size:0.8em;\n    background-position:top right;\n    background-color: #FCFCFC;\n    padding-left:20px;\n    padding-right:10px;\n    overflow:hidden;\n    position:relative;\n    clear:both;\n    color: black;\n}\n.AccordionPane .panelContent div {\n    position:relative;\n    padding-top:2px;\n    padding-bottom:2px;\n}\n.AccordionPane .panelContent a {\n    color:black;\n    text-decoration:none;\n    outline:0;\n}\n.AccordionPane .panelContent a:hover{\n    color:#5B626A;\n}\n.AccordionPane .dhtmlgoodies_panel .topBar{\n    background-color: #C6C0C6;\n    height:25px;\n    padding-right:0;\n    cursor:pointer;\n    overflow:hidden;\n    border-radius: 3px 3px 3px 3px;\n    box-shadow: 0px 4px 10px -1px rgba(100, 100, 100, 0.8); \n}\n\n.AccordionPane .dhtmlgoodies_panel .topBar:hover {\n    background-color: #DCCED1;\n}\n\n.AccordionPane .dhtmlgoodies_panel .topBar span{\n    line-height:25px;\n    vertical-align:middle;\n    font-family:arial;\n    font-size:0.7em;\n    color:black;\n    font-weight:bold;\n    float:left;\n    padding-left:5px;\n}\n.AccordionPane .dhtmlgoodies_panel .topBar img{\n    float:right;\n    cursor:pointer;\n}\n"
          },
