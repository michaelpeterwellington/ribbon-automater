alue>=2){r=tabNavigationContext.getElementById(\"sbaVmRowNetworkAdapterUpTo1\")\n}else{r=tabNavigationContext.getElementById(\"sbaVmRowNetworkAdapterUpTo2\")}r.style.display=\"none\";handleSBAPortEvent();e.style.display=\"none\";u.style.display=\"\";var a=g.value;removeAllOptions(g);for(var s=1;\ns<=y.value;s++){g.options[s-1]=new Option(s,s)}g.value=a}else{if((l.value==\"Running\"&&m.value!=\"Unknown\")||(b&&b.value==\"Office 365 CCE\")){var p=tabNavigationContext.getElementById(\"sbaVmRowDescription\");\nvar A=tabNavigationContext.getElementById(\"sbaVmRowLogicalCpu\");var d=tabNavigationContext.getElementById(\"sbaVmRowAssignedMemory\");var w=tabNavigationContext.getElementById(\"sbaVmRowNetworkAdapterUpTo1\");\nvar j=tabNavigationContext.getElementById(\"sbaVmRowNetworkAdapterUpTo2\");var o=tabNavigationContext.getElementById(\"NetworkAdapter-Hidden\");var f=tabNavigationContext.getElementById(\"sbaVmFGNetworkConfiguration\");\np.style.display=\"none\";A.style.display=\"none\";d.style.display=\"none\";w.style.display=\"none\";j.style.display=\"none\";if(o.value==\"0\"){var z=tabNavigationContext.getElementById(\"popup2_SubmitBar\");if(z){z.style.display=\"none\"\n}}handleSBAPortEvent();u.style.display=\"none\";if(l.value==\"Running\"){v.innerHTML=\"Hardware configuration can not be modified since the VM is running.\";e.style.display=\"\"}else{if(b.value==\"Office 365 CCE\"){f.style.display=\"none\"\n}}}else{var p=tabNavigationContext.getElementById(\"sbaVmRowDescription\");var A=tabNavigationContext.getElementById(\"sbaVmRowLogicalCpu\");var d=tabNavigationContext.getElementById(\"sbaVmRowAssignedMemory\");\nvar w=tabNavigationContext.getElementById(\"sbaVmRowNetworkAdapterUpTo1\");var j=tabNavigationContext.getElementById(\"sbaVmRowNetworkAdapterUpTo2\");var f=tabNavigationContext.getElementById(\"sbaVmFGNetworkConfiguration\");\nvar n=\"popup\"+k.value+\"_SubmitBar\";var z=tabNavigationContext.getElementById(n);p.style.display=\"none\";A.style.display=\"none\";d.style.display=\"none\";w.style.display=\"none\";j.style.display=\"none\";f.style.display=\"none\";\nif(z){z.style.display=\"none\"}u.style.display=\"none\";v.innerHTML=\"Guest VM inaccessible: some information is  not available.\";e.style.display=\"\"}}}function setCCEIpDetails(){var c=document.getElementById(\"__m_ASMImageType-Hidden\");\nvar h=tabNavigationContext.getElementById(\"sbaASMIpRO1\");var n=tabNavigationContext.getElementById(\"sbaASMIpRW1\");var f=tabNavigationContext.getElementById(\"sbaASMIpRO2\");var m=tabNavigationContext.getElementById(\"sbaASMIpRW2\");\nvar k=tabNavigationContext.getElementById(\"ASMVMIPConfig-Banner\");var g=tabNavigationContext.getElementById(\"ASMVMIPConfig-BannerText\");if(c&&c.value==\"Office 365 CCE\"){var l=tabNavigationContext.getElementById(\"DHCPEnabled1-Field\");\nvar j=tabNavigationContext.getElementById(\"DHCPEnabled2-Field\");var i=tabNavigationContext.getElementById(\"OKButton\");var d=tabNavigationContext.getElementById(\"DHCPEnabled1dr\");var a=tabNavigationContext.getElementById(\"DHCPEnabled2dr\");\nvar b=$uxDocQuery(\"#\"+d.id);var e=$uxDocQuery(\"#\"+a.id);g.innerHTML=\"Network Configuration can only be modified in the Setup Cloud Connector task.\";k.style.display=\"\";b.html('<td class=\"FormName\">DHCP Enabled</td><td class=\"FormValue\"><span><b>'+l.options[l.selectedIndex].text+\"</b></span></td><td></td>\");\ne.html('<td class=\"FormName\">DHCP Enabled</td><td class=\"FormValue\"><span><b>'+j.options[j.selectedIndex].text+\"</b></span></td><td></td>\");n.style.display=\"none\";h.style.display=\"\";m.style.display=\"none\";\nf.style.display=\"\";i.style.display=\"none\"}}function handleSBAPortEvent(){var a=tabNavigationContext.getElementById(\"NetworkAdapter-Hidden\");var c=tabNavigationContext.getElementById(\"sbaASMIp1FG\");var b=tabNavigationContext.getElementById(\"sbaASMIp2FG\");\nif(a.value==\"0\"||a.value==\"4\"){c.style.display=\"none\";b.style.display=\"none\"}else{if(a.value==\"1\"||a.value==\"2\"){c.style.display=\"\";b.style.display=\"none\"}else{if(a.value==\"3\"){c.style.display=\"\";b.style.display=\"\"\n}}}handleSBAVmDHCPPortEvent()}function handleSBAVmDHCPPortEvent(){var h=tabNavigationContext.getElementById(\"NetworkAdapter-Hidden\");var g=tabNavigationContext.getElementById(\"DHCPEnabled1-Field\");var d=tabNavigationContext.getElementById(\"sbaASMIpRO1\");\nvar i=tabNavigationContext.getElementById(\"sbaASMIpRW1\");var e=tabNavigationContext.getElementById(\"DHCPEnabled2-Field\");var c=tabNavigationContext.getElementById(\"sbaASMIpRO2\");var f=tabNavigationContext.getElementById(\"sbaASMIpRW2\");\nvar a=tabNavigationContext.getElementById(\"ipGatewayRW\");var b=tabNavigationContext.getElementById(\"ipGatewayRO\");if(h.value==\"0\"){b.style.display=\"none\";a.style.display=\"none\";return}else{if(((h.value==\"1\"||h.value==\"2\")&&g.value==0)||(h.value==\"3\"&&(g.value==0||e.value==0))){b.style.display=\"none\";\na.style.display=\"\"}else{if(h.value==\"3\"&&(g.value==1||e.value==1)){alert(\"Configuring both VM Network adapter as DHCP client can generate conflict\\n if not properly configured into the DHCP server.\");a.style.display=\"none\";\nb.style.display=\"\"}else{a.style.display=\"none\";b.style.display=\"\"}}}if(g.value==1){i.style.display=\"none\";d.style.display=\"\"}else{i.style.display=\"\";d.style.display=\"none\"}if(e.value==1){f.style.display=\"none\";\nc.style.display=\"\"}else{f.style.display=\"\";c.style.display=\"none\"}}function validateASMVirtualMachineUpdate(h){var k=tabNavigationContext.getElementById(\"State-Hidden\");var e=tabNavigationContext.getElementById(\"Hostname-Hidden\");\nvar n=tabNavigationContext.getElementById(\"NetworkAdapter-Hidden\");if(k.value==\"Running\"&&e.value!=\"Unknown\"){var m=tabNavigationContext.getElementById(\"DHCPEnabled1-Field\");var l=tabNavigationContext.getElementById(\"DHCPEnabled2-Field\");\nvar c=tabNavigationContext.getElementById(\"ipAddress2-Field\");var i=tabNavigationContext.getElementById(\"ipNetmask2-Field\");if(n.value!=\"0\"){var g=\"\";if(m&&m.value==0){var d=tabNavigationContext.getElementById(\"ipAddress1-Field\");\nif(d){if(d.value==\"\"){g+=\"\\n- Adapter 1 IP Address is mandatory. Please enter the IP address in x.x.x.x format.\"}else{if((hasBlacklistedCharacters(d,false))||(!(isIpAddress(d.value)))){g+=\"\\n- Adapter 1 IP Address format is incorrect. Please enter the IP address in x.x.x.x format.\"\n}}}var j=tabNavigationContext.getElementById(\"ipNetmask1-Field\");if(j){if(j.value==\"\"){g+=\"\\n- Adapter 1 Address Mask is mandatory. Please enter the Mask in x.x.x.x format.\"}else{if((hasBlacklistedCharacters(j,false))||(!(isIPv4NetMask(j.value)))){g+=\"\\n- Adapter 1 Address Mask format is incorrect. Please enter the Mask in x.x.x.x format.\"\n}else{if((endsWith(j.value,\".255\"))||endsWith(j.value,\".254\")){g+=\"\\n- Adapter 1 Address Mask format is incorrect. Please enter the Mask lower than 255.255.255.254.\"}}}}var b=tabNavigationContext.getElementById(\"DNSServerPref1-Field\");\nif(b){if((b.value!=\"\")&&(hasBlacklistedCharacters(b,false)||(!(isIpAddress(b.value))))){g+=\"\\n- Adapter 1 Preferred DNS format is incorrect. Please enter the DNS Adddress in x.x.x.x format.\"}}DNSServerAlt1=tabNavigationContext.getElementById(\"DNSServerAlt1-Field\");\nif(DNSServerAlt1){if((DNSServerAlt1.value!=\"\")&&(hasBlacklistedCharacters(DNSServerAlt1,false)||(!(isIpAddress(DNSServerAlt1.value))))){g+=\"\\n- Adapter 1 Alternate DNS format is incorrect. Please enter the DNS Adddress in x.x.x.x format.\"\n}}ipGateway=tabNavigationContext.getElementById(\"ipGateway-Field\");if(ipGateway){if((ipGateway.value!=\"\")&&(hasBlacklistedCharacters(ipGateway,false)||(!(isIpAddress(ipGateway.value))))){g+=\"\\n- Adapter 1 Default Gateway format is incorrect. Please enter the Default Gateway Adddress in x.x.x.x format.\"\n}}}}if(n.value==\"3\"){if(l&&l.value==0){var c=tabNavigationContext.getElementById(\"ipAddress2-Field\");if(c){if(c.value==\"\"){g+=\"