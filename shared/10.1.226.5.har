quired and must be in IPv4 address format\"}}}if(o.value==\"6\"||o.value==\"17\"||o.value==\"132\"){if(isVSBCE()){if((isNaN(h.value))||(h.value==\"\")||(h.value<0)||(h.value>65535)){F=1;\nA+=\"\\n-Source port should be between 0 and 65535\"}if((isNaN(j.value))||(j.value==\"\")||(j.value<0)||(j.value>65535)){F=1;A+=\"\\n-Destination port should be between 0 and 65535\"}}else{if((isNaN(u.value))||(u.value==\"\")||(u.value<0)||(u.value>65535)){F=1;\nA+=\"\\n- Minimum Source port should be between 0 and 65535\"}if((isNaN(z.value))||(z.value==\"\")||(z.value<0)||(z.value>65535)){F=1;A+=\"\\n- Maximum Source port should be between 0 and 65535\"}if((isNaN(k.value))||(k.value==\"\")||(k.value<0)||(k.value>65535)){F=1;\nA+=\"\\n- Minimum Destination port should be between 0 and 65535\"}if((isNaN(C.value))||(C.value==\"\")||(C.value<0)||(C.value>65535)){F=1;A+=\"\\n- Maximum Destination port should be between 0 and 65535\"}if(!F){var s=0;\nvar d=0;var G=0;var x=0;s=parseInt(u.value);d=parseInt(z.value);G=parseInt(k.value);x=parseInt(C.value);if(s>d){A+=\"\\n- Minimum Source port should be less than or equal to Maximum Source port\"}if(G>x){A+=\"\\n- Minimum Destination port should be less than or equal to Maximum Destination port\"\n}}}}if(isVSBCE()){var c=tabNavigationContext.getElementById(\"currentACLPrecedence-Hidden\");var r=tabNavigationContext.getElementById(\"curPrecedences-Hidden\");var e=tabNavigationContext.getElementById(\"aclPrecedence-Field\");\nvar B=tabNavigationContext.getElementById(\"formattedPrecedences-Hidden\");var b=r.value.split(\",\");if(e.value!=c.value){if($uxDocQuery.inArray(e.value,b)>-1){A+=\"\\n- Precedence value needs to be unique across all ACL rules. \\n     - Please select a value in the range 1001 - 65535, other than the following reserved or used precedence values: \\n\"+B.value\n}}var D=tabNavigationContext.getElementById(\"aclPortNumberSel-Field\");var w=tabNavigationContext.getElementById(\"aclTcpServices-Field\");var a=tabNavigationContext.getElementById(\"ifName-Field\");if(o.value==\"6\"){if((w.options[w.selectedIndex].value==\"0\")&&(D.options[D.selectedIndex].value==\"1\")){A+=\"\\n- A valid Service must be selected.\"\n}}if((a.options[a.selectedIndex].value==\"none\")){A+=\"\\n- A valid Interface must be selected.\"}var E=tabNavigationContext.getElementById(\"ribbonProtectBadActor-Hidden\");if(E.value==\"1\"){A+=\"\\n-The rule shall be updated only through Ribbon Protect Bad Actors\"\n}}if(A!=\"\"){alert(\"The following errors were found with the ACL Rule entry.\\n\"+A);document.MM_returnValue=false}else{if(isVSBCE()){var m=tabNavigationContext.getElementById(\"aclAction-Field\");if(D.options[D.selectedIndex].value==\"1\"){if((w.options[w.selectedIndex].value==\"443\")&&(m.options[m.selectedIndex].value==\"1\")&&((a.options[a.selectedIndex].value==\"mgt0\")||(a.options[a.selectedIndex].text==\"Any\"))){var l=\"Applying these changes could impact ability to manage the \"+brandingUtil.getProductClassName()+\" via web browser.\\n\\nAre you sure you want to continue?\";\nif(confirm(l)){document.MM_returnValue=true}else{document.MM_returnValue=false}}else{document.MM_returnValue=true}}else{document.MM_returnValue=true}}else{document.MM_returnValue=true}}}function aclProtocolUpdated(){var d=tabNavigationContext.getElementById(\"aclProtocol-Field\");\nvar a=tabNavigationContext.getElementById(\"otherProtocolRowId\");var b=tabNavigationContext.getElementById(\"aclPortNumberSel-Field\");var c=tabNavigationContext.getElementById(\"aclPortNumberSelRowId\");if(d.value==\"6\"||d.value==\"17\"){c.style.display=\"\";\naclPortNumberSelUpdated(b)}else{if(d.value==\"132\"){c.value=\"4\";aclPortNumberSelUpdated(c)}else{c.value=\"4\";aclPortNumberSelUpdated(c)}}if(d.value==\"other\"){a.style.display=\"\"}else{a.style.display=\"none\"\n}}function aclPortNumberSelUpdated(k){if(isVSBCE()){var c=tabNavigationContext.getElementById(\"aclSrcPortRowId\");var h=tabNavigationContext.getElementById(\"aclDstPortRowId\");if(getContainerType()==\"1\"){var l=tabNavigationContext.getElementById(\"SourceID\")\n}}else{var b=tabNavigationContext.getElementById(\"aclMinSrcPortRowId\");var f=tabNavigationContext.getElementById(\"aclMaxSrcPortRowId\");var e=tabNavigationContext.getElementById(\"aclMinDstPortRowId\");var g=tabNavigationContext.getElementById(\"aclMaxDstPortRowId\")\n}var j=tabNavigationContext.getElementById(\"aclProtocol-Field\");var a=tabNavigationContext.getElementById(\"aclTcpServicesRowId\");var d=tabNavigationContext.getElementById(\"aclUdpServicesRowId\");if(k.value==\"1\"){if(isVSBCE()){if(getContainerType()==\"1\"){l.style.display=\"none\"\n}c.style.display=\"none\";h.style.display=\"none\"}else{b.style.display=\"none\";f.style.display=\"none\";e.style.display=\"none\";g.style.display=\"none\"}if(j.value==\"6\"){d.style.display=\"none\";a.style.display=\"\"\n}else{if(j.value==\"17\"){d.style.display=\"\";a.style.display=\"none\"}}}else{if(k.value==\"2\"){if(isVSBCE()){if(getContainerType()==\"1\"){l.style.display=\"\"}c.style.display=\"\";h.style.display=\"\"}else{b.style.display=\"\";\nf.style.display=\"\";e.style.display=\"\";g.style.display=\"\"}d.style.display=\"none\";a.style.display=\"none\"}else{k.style.display=\"none\";d.style.display=\"none\";a.style.display=\"none\";if(j.value==\"132\"){if(isVSBCE()){if(getContainerType()==\"1\"){l.style.display=\"\"\n}c.style.display=\"\";h.style.display=\"\"}else{b.style.display=\"\";f.style.display=\"\";e.style.display=\"\";g.style.display=\"\"}}else{if(isVSBCE()){if(getContainerType()==\"1\"){l.style.display=\"none\"}c.style.display=\"none\";\nh.style.display=\"none\"}else{b.style.display=\"none\";f.style.display=\"none\";e.style.display=\"none\";g.style.display=\"none\"}}}}return true}function formatPrecedence(){var c=tabNavigationContext.getElementById(\"curPrecedences-Hidden\");\nvar a=c.value.split(\",\");a=a.sort(function(f,e){return f-e});var d=a.reduce(formatAvailablePrecedenceStr,0);var b=tabNavigationContext.getElementById(\"formattedPrecedences-Hidden\");b.value=d}function deleteRoute(){var a=SelectedIDs();\nif(a==\"\"){alert(\"Please select static route(s) to be deleted\");return false}var c=a.split(\";\");var h=false;var g;for(var d=0;d<c.length;d++){var e=c[d].split(\",\");if(e.length>1&&e[1]!=\"Static\"){h=true;\nbreak}}var j=\"\";if(h){j=\"Only static route(s) can be deleted. Non-static route(s) are selected, but will not get deleted.\\n\"}var b=j+\"Are you sure that you want to delete the selected static route(s)?\";\nvar f=confirm(b);if(!f){return false}return true}function routeValidate(){if(!document.popup.ipRouteDisVar){return false}var a=document.popup.ipRouteDisVar.value;if(isNaN(a)||Number(a)<1||Number(a)>255){alert(\"Incorrect distance value is entered. Please correct the error first\");\nreturn false}return true}function routeAddValidate(){var b=document.popup.ipRoutePrefixVar.value;var a=\"\";if(b.indexOf(\"/\")<0){a=\"        - Mask is required for IP Destination Prefix\\n\"}if(!ipAddrFormatCheck(document.popup.ipRoutePrefixVar,\"false\")){a+=\"      - Incorrect Destination Prefix is entered. Please enter it in A.B.C.D/M format \\n\"\n}b=document.popup.ipRouteGatewayVar.value;if(b.indexOf(\"/\")>-1||!ipAddrFormatCheck(document.popup.ipRouteGatewayVar,\"false\")){a+=\"      - Incorrect Gateway address is entered. Please enter it in A.B.C.D format\\n\"\n}b=document.popup.ipRouteDisVar.value;if(b!=\"\"&&(isNaN(b)||Number(b)<1||Number(b)>255)){a+=\"      - Incorrect distance is entered. Please enter a value between 1 and 255.\\n\"}if(a!=\"\"){alert(\"There are errors in adding the static route. Please correct them first.\\n\\n\"+a);\nreturn false}return true}function ipAddrFormatCheck(g,e){var h=g.value;if(h==\"\"){if(e==\"true\"){return true}else{return false}}var d=\"\";var b=h.split(\"/\");if(b.length==2){h=b[0];d=b[1]}try{var c=h.split(\".\");\nif(c.length!=4){return false}for(var a=0;a<4;a++){if(isNaN(c[a])||Number(c[a])<0||Number(c[a])>255){return false}}if(d!=\"\"&&(isNaN(d)||Number(d)<0||Number(d)>32)){return false}}catch(f){return false}return true\n}function ipRouteOnLoad(a){handleRouteTypeChange(a)}function validateIPRouteEntry(d){var c=\"popup\";if(d){c=d.name}var a=\"\";var b;if(document.forms[c].elements.ipDestinationAddr){b=document.forms[c].elements.ipDestinationAddr;\nif((hasBlacklistedCharacters(b,false))||(!(isIpAddress(b.value)))){a+=\"\\n- IP Address format is incorrect. Please enter the Destination IP in x.x.x.x format.\"}}if(document.forms[c].elements.ipDestinationMask){if((hasBlacklistedCharacters(document.forms[c].elements.ipDestinationMask,false))||(!(isIpAddress(document.forms[c].elements.ipDestinationMask.value)))){a+=\"\\n- Address Mask format is incorrect. Please enter the Mask in x.x.x.x format.\"\n}}if(document.forms[c].elements.ipNexthopAddress){b=document.forms[c].elements.ipNexthopAddress;if((hasBlacklistedCharacters(b,false))||(!(isIpAddress(b.value)))){a+=\"\\n- Gateway format is incorrect. Please enter the gateway address in x.x.x.x format.\"\n}}if(document.forms[c].elements.ipStaticRouteMetric){b=document.forms[c].elements.ipStaticRouteMetric;var e=b.value;if(hasBlacklistedCharacters(b,false)||e==\"\"||(e!=\"\"&&(isNaN(e)||Number(e)<1||Number(e)>250))){a+=\"\\n- Route Metrics is incorrect. Please enter the value within [1..250] range.\"\n}}if(a!=\"\"){alert(\"The following errors were found with the Static IP Route entry.\\n\"+a);document.MM_returnValue=false}else{document.MM_returnValue=true}}function validateIPv6RouteEntry(d){var c=\"popup\";\nif(d){c=d.name}var a=\"\";var b;if(document.forms[c].elements.ipDestinationAddr){b=document.forms[c].elements.ipDestinationAddr;if((hasBlacklistedCharacters(b,false))||(!(isIPv6Address(b.value)))){a+=\"\\n- IP Address format is incorrect. Please enter the Destination IP in x:x::x:x format.\"\n}}if(document.forms[c].elements.ipGatewayType.value==\"0\"){if(document.forms[c].elements.ipNexthopAddress){b=document.forms[c].elements.ipNexthopAddress;if((hasBlacklistedCharacters(b,false))||(!(isIPv6Address(b.value)))||(isIPv6AddressZero(b.value))){a+=\"\\n- Gateway format is incorrect. Please enter the gateway address in x:x::x:x format.\"\n}}}if(document.forms[c].elements.ipStaticRouteMetric){b=document.forms[c].elements.ipStaticRouteMetric;var e=b.value;if(hasBlacklistedCharacters(b,false)||e==\"\"||(e!=\"\"&&(isNaN(e)||Number(e)<1||Number(e)>250))){a+=\"\\n- Route Metric is incorrect. Please enter the value within [1..250] range.\"\n}}if(a!=\"\"){alert(\"The following errors were found with the Static IPv6 Route entry.\\n\"+a);document.MM_returnValue=false}else{document.MM_returnValue=true}}function handleRouteTypeChange(b){var a=\"popup\";\nif(b){a=b.name}if(document.forms[a].elements.ipGatewayType){var c=document.forms[a].elements.ipGatewayType;if(c!=null){if(c.value==\"0\"){tabNavigationContext.getElementById(\"ifName-Row\").style.display=\"none\";\ntabNavigationContext.getElementById(\"gatewayRow-ID\").style.display=\"\";tabNavigationContext.getElementById(\"gatewayRow_LL-ID\").style.display=\"none\"}else{tabNavigationContext.getElementById(\"ifName-Row\").style.display=\"\";\ntabNavigationContext.getElementById(\"gatewayRow-ID\").style.display=\"none\";tabNavigationContext.getElementById(\"gatewayRow_LL-ID\").style.display=\"\"}}}}function validateARPEntry(c){var a=\"popup\";if(c){a=c.name\n}var b=\"\";if(document.forms[a].elements.ifHwAddress){if((hasBlacklistedCharacters(document.forms[a].elements.ifHwAddress,false))||(!(isMacAddress(document.forms[a].elements.ifHwAddress.value)))){b+=\"\\n- MAC Address format is incorrect. Please enter the MAC address in xx:xx:xx:xx:xx:xx format.\"\n}}if(document.forms[a].elements.ifIPAddress){if((hasBlacklistedCharacters(document.forms[a].elements.ifIPAddress,false))||(!(isIpAddress(document.forms[a].elements.ifIPAddress.value)))){b+=\"\\n- IP Address format is incorrect. Please enter the IP address in x.x.x.x format.\"\n}}if(document.forms[a].elements.ifIPAddressMask){if((hasBlacklistedCharacters(document.forms[a].elements.ifIPAddressMask,false))||(!(isIpAddress(document.forms[a].elements.ifIPAddressMask.value)))){b+=\"\\n- Address Mask format is incorrect. Please enter the Mask in x.x.x.x format.\"\n}}if(b!=\"\"){alert(\"The following errors were found with the ARP entry.\\n\"+b);document.MM_returnValue=false}else{document.MM_returnValue=true}}function validateIPv6NeighborEntry(c){var a=\"popup\";if(c){a=c.name\n}var b=\"\";if(document.forms[a].elements.ifHwAddress){if((hasBlacklistedCharacters(document.forms[a].elements.ifHwAddress,false))||(!(isMacAddress(document.forms[a].elements.ifHwAddress.value)))){b+=\"\\n- MAC Address format is incorrect. Please enter the MAC address in xx:xx:xx:xx:xx:xx format.\"\n}}if(document.forms[a].elements.ifIPAddress){if((hasBlacklistedCharacters(document.forms[a].elements.ifIPAddress,false))||(!(isIPv6Address(document.forms[a].elements.ifIPAddress.value)))){b+=\"\\n- IPv6 Address format is incorrect. Please enter the IPv6 address in x:x::x:x format.\"\n}}if(document.forms[a].elements.ifName){if((document.forms[a].elements.ifName.value==\"\")||(document.forms[a].elements.ifName.value==\"none\")){b+=\"\\n- Interface must be selected.\"}}if(b!=\"\"){alert(\"The following errors were found with the Neighbor entry.\\n\"+b);\ndocument.MM_returnValue=false}else{document.MM_returnValue=true}}function formatAvailablePrecedenceStr(e,d,c,a){var f=\"\";if(c==0){f=d;return\"[\"+f}if(d-a[c-1]==1){if(c==(a.length-1)){e+=\"-\"+d+\"]\"}else{var b=e.slice(-1);\nif(b!=\"-\"){e+=\"-\"}}}else{var b=e.slice(-1);if(b==\"-\"){e+=a[c-1]+\"], [\"+d}else{e+=\"], [\"+d}if(c==(a.length-1)){e+=\"]\"}}return e}function initAcl(){if(isVSBCE()){var b=tabNavigationContext.getElementById(\"parentID-Hidden\");\nvar c=tabNavigationContext.getElementById(\"OKButton\");var a=tabNavigationContext.getElementById(\"ribbonProtectBadActor-Hidden\");if(getContainerType()==\"0\"){if(b.value==\"1\"||b.value==\"2\"||b.value==\"3\"||a.value==\"1\"){if(c){c.style.display=\"none\"\n}}}else{if(a.value==\"1\"){if(c){c.style.display=\"none\"}}}}aclProtocolUpdated();formatPrecedence()}function configurePingIpAddrType(){var b=tabNavigationContext.getElementById(\"IpAddrType-Field\");var a=tabNavigationContext.getElementById(\"IpAddr-Row\").getElementsByClassName(\"details\");\nif(b.value==0){a[0].innerHTML=\"FQDN or IP\";tabNavigationContext.getElementById(\"Interface_v4-Row\").style.display=\"\";tabNavigationContext.getElementById(\"Interface_v6-Row\").style.display=\"none\"}else{a[0].innerHTML=\"FQDN or IPv6\";\ntabNavigationContext.getElementById(\"Interface_v4-Row\").style.display=\"none\";tabNavigationContext.getElementById(\"Interface_v6-Row\").style.display=\"\"}}function pingObject(){this.pingResults=\"\";this.pingActive=false;\nthis.pingIpAddrType=0;this.pingIP=\"\";this.pingInterface=\"\";this.pingTimeout=0;this.pingTotalCount=0;this.pingCancel=false;this.pingInterval=0;this.pingPacketSize=0}png=new pingObject();function initPingDestination(){var c=tabNavigationContext.getElementById(\"results-id\");\nvar a=tabNavigationContext.getElementById(\"resultsRow\");var b=tabNavigationContext.getElementById(\"IpAddrType-Field\");c.style.display=\"\";a.style.display=\"\";if(png.pingIpAddrType!=0){tabNavigationContext.getElementById(\"IpAddrType-Field\").value=png.pingIpAddrType\n}if(png.pingIP!=\"\"){tabNavigationContext.getElementById(\"IpAddr-Field\").value=png.pingIP}if(png.pingInterface!=\"\"){if(b.value==0){tabNavigationContext.getElementById(\"interface_v4-Field\").value=png.pingInterface\n}else{tabNavigationContext.getElementById(\"interface_v6-Field\").value=png.pingInterface}}if(png.pingTotalCount!=0){tabNavigationContext.getElementById(\"count-Field\").value=png.pingTotalCount}if(png.pingInterval!=0){tabNavigationContext.getElementById(\"interval-Field\").value=png.pingInterval\n}if(png.pingTimeout!=0){tabNavigationContext.getElementById(\"timeout-Field\").value=png.pingTimeout}if(png.pingResults!=\"\"){tabNavigationContext.getElementById(\"pingResults-Field\").value=png.pingResults;\ntabNavigationContext.getElementById(\"pingResults-Field\").scrollTop=tabNavigationContext.getElementById(\"pingResults-Field\").scrollHeight+500}if(png.pingPacketSize!=0){tabNavigationContext.getElementById(\"packetSize-Field\").value=png.pingPacketSize\n}if(isHA()!=\"2\"){if(png.pingActive==true||tr.traceRouteActive==true||cp.checkPortActive==true){tabNavigationContext.getElementById(\"OKButton\").disabled=true}else{tabNavigationContext.getElementById(\"OKButton\").disabled=false\n}}configurePingIpAddrType()}function PingDest(){var a=tabNavigationContext.getElementById(\"IpAddrType-Field\");var m=tabNavigationContext.getElementById(\"IpAddr-Field\");var n=tabNavigationContext.getElementById(\"timeout-Field\");\nvar o=tabNavigationContext.getElementById(\"count-Field\");var l=tabNavigationContext.getElementById(\"interval-Field\");qInterface=tabNavigationContext.getElementById(\"interface_v4-Field\");if(a.value==\"1\"){qInterface=tabNavigationContext.getElementById(\"interface_v6-Field\")\n}var h=tabNavigationContext.getElementById(\"packetSize-Field\");var d=5000;var e=0;var g=0;var c=0;var b=0;var k=\"\";if((a.value==0)&&(!isIpAddress(m.value))&&(!isValidDnsName(m.value))){k+=\"\\n- Invalid IP Address or FQDN\"\n}if((a.value==1)&&(!isValidDnsName(m.value))&&(!isIPv6Address(m.value))){k+=\"\\n- Invalid IPv6 Address or FQDN\"}if(!(isNumberWithinRange(o.value,1,720))){k+=\"\\n- Count must be between 1 and 720\"}if(!(isNumberWithinRange(l.value,1,5))){k+=\"\\n- Interval must be between 1 and 5\"\n}if(!(isNumberWithinRange(n.value,1,10))){k+=\"\\n- Timeout must be between 1 and 10\"}if(!(isNumberWithinRange(h.value,1,2000))){k+=\"\\n- Packet Size must be between 1 and 2000\"}if(k!=\"\"){alert(\"The following errors were found:\\n\"+k);\ndocument.MM_returnValue=false;return}var j=m.value;var f=a.value;png.pingIpAddrType=a.value;png.pingIP=m.value;png.pingInterface=qInterface.v