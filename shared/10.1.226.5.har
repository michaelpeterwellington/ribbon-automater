          "content": {
            "size": 8154,
            "mimeType": "text/javascript",
            "text": "/************************************************************************************************************\n DG Filter\n Copyright (C) 2009  DTHMLGoodies.com, Alf Magne Kalleland\n\n This library is free software; you can redistribute it and/or\n modify it under the terms of the GNU Lesser General Public\n License as published by the Free Software Foundation; either\n version 2.1 of the License, or (at your option) any later version.\n\n This library is distributed in the hope that it will be useful,\n but WITHOUT ANY WARRANTY; without even the implied warranty of\n MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the GNU\n Lesser General Public License for more details.\n\n You should have received a copy of the GNU Lesser General Public\n License along with this library; if not, write to the Free Software\n Foundation, Inc., 51 Franklin Street, Fifth Floor, Boston, MA  02110-1301  USA\n\n Dhtmlgoodies.com., hereby disclaims all copyright interest in this script\n written by Alf Magne Kalleland.\n\n Alf Magne Kalleland, 2009\n Owner of DHTMLgoodies.com\n\n ************************************************************************************************************/\n\n/**\n * Modified the orginal source to remove the dependency on mootools and\n * make use of jquery\n * \n * @param propArray\n */\nDGFilter = function (propArray) {\n    var xPathFilterElements = false;\n    /** Css class for text elements to be indexed */\n    var filterField = null;\n    /** Reference to text field */\n    var filterEl = null;\n    /** Reference to element to be filtered */\n    var filterElType = null;\n    var searchIndex = null;\n    var onMatchShowChildren = false;\n    var idCounter = 0;\n    var matchedNodes = null;\n    /** Temporary array of matched nodes */\n    var txtNoMatchFound = '';\n    /** No matches found text */\n\n    if (propArray) this.__initialize(propArray);\n}\nDGFilter.prototype =\n{\n    /**\n     *\n     */\n    __initialize : function(props) {\n        this.filterField = props['filterField'];\n        this.filterEl = props['filterEl'];\n        this.xPathFilterElements = props['xPathFilterElements'];\n        this.filterElType = this.filterEl.tagName.toLowerCase() == 'table' ? 'table' : 'list';\n        this.onMatchShowChildren = props['onMatchShowChildren'];\n        this.txtNoMatchFound =  'No matches found';\n        this.listeners = props['listeners'] || null;\n\n        this.addFilterEvents();\n        this.createSearchIndex();\n        this._createNoMatchFoundElement();\n    },\n\n    _setNewNodeId : function(node) {\n        node.setProperty('id', 'dgfilter' + this.idCounter);\n        this.idCounter++;\n\n    },\n    /**\n     * Create search index - makes the search work faster\n     */\n    createSearchIndex : function() {\n        var elements;\n        if (this.filterElType == 'list') {\n            elements = this.filterEl.getElementsByTagName('li');\n        } else {\n            elements = this.filterEl.getElements('tbody')[0].getElements('tr');\n        }\n        var textProperty = document.body.innerText ? 'innerText' : 'textContent';\n        this.searchIndex = [];\n\n        for (var i = 0; i < elements.length; i++) {\n            if (!elements[i].id) {\n                this._setNewNodeId(elements[i]);\n            }\n            var textContent = '';\n            var firstParent = null;\n            if (this.xPathFilterElements) {\n                var textElements = this.filterElType == 'list' ? [elements[i].getElementsByTagName(this.xPathFilterElements)[0]] : elements[i].getElementsByTagName(this.xPathFilterElements)[0];\n                for (var j = 0; j < textElements.length; j++) {\n                    textContent = textContent + textElements[j].title;\n                }\n            }\n\n            this.searchIndex.push({\n                itemText : textContent.toLowerCase(),\n                branchText : this.findBranchText(elements[i], ' '),\n                el : elements[i],\n                parentEl : (this.filterElType == 'list' && i > 0) ? elements[i].parentNode.getElementsByTagName('li')[0] : null\n            });\n        }\n\n\n    },\n\n    findBranchText : function(liElement, prependChar) {\n        var branchText = '';\n        var aElement = liElement.getElementsByTagName('a')[0];\n        branchText += (prependChar + aElement.title);\n\n        var childElements = liElement.getElementsByTagName('li');\n        for (var i = 0; i < childElements.length; i++) {\n            aElement = childElements[i].getElementsByTagName('a')[0];\n            branchText += '\\n' + aElement.title;\n        }\n        return branchText.toLowerCase();\n    },\n\n    addFilterEvents : function() {\n        $uxDocQuery(this.filterField).bind({\n           keyup : $uxDocQuery.proxy(this, 'filter'),\n           paste : $uxDocQuery.proxy(this, 'filter'),\n           click : $uxDocQuery.proxy(this, 'filter')\n        });\n    },\n\n    _showNode : function(node) {\n        node.el.style.display = '';\n    },\n    _hideNode : function(node) {\n        node.el.style.display = 'none';\n    },\n\n    clearFilter : function() {\n        this.matchedNodes = {};\n        this.filterList('');\n        this._hideNoMatchFoundText();\n    },\n\n    filter : function() {\n        if (this.listeners) {\n            try {\n                eval(this.listeners);\n            } catch (e) {}\n        }\n        this.matchedNodes = {};\n        if (!this.searchIndex) {\n            this.createSearchIndex();\n        }\n        var searchPhrase = this.filterField.value.toLowerCase();\n        if (this.filterElType == 'list') {\n            var matchesFound = this.filterList(searchPhrase);\n        }\n        else {\n            var matchesFound = this.filterTable(searchPhrase);\n        }\n\n        if (!matchesFound) {\n            this._showNoMatchFoundElement();\n        } else {\n            this._hideNoMatchFoundText();\n        }\n    },\n\n    _matchAbove : function(node) {\n        return this.matchedNodes[node.id];\n    },\n\n    _nodeMatch : function(indexNode, searchPhrase) {\n        return indexNode.branchText.indexOf(searchPhrase) >= 0;\n    },\n\n    storeNodeMatch : function(indexNode, searchPhrase) {\n        if (!this.onMatchShowChildren) {\n            return;\n        }\n        var match = indexNode.itemText.indexOf(searchPhrase) >= 0;\n        if (!match && indexNode.parentEl) {\n            match = this.matchedNodes[indexNode.parentEl.id];\n        }\n        this.matchedNodes[indexNode.id] = match;\n    },\n    _getIdOfNoMatchFoundElement : function() {\n        return this.filterEl.id + 'noMatchFound';\n    },\n    _hideNoMatchFoundText : function() {\n        var el = this._getIdOfNoMatchFoundElement();\n        if (el) {\n            $uxDocQuery('#' + el).css('display', 'none');\n        }\n    },\n    _showNoMatchFoundElement : function() {\n        var el = this._getIdOfNoMatchFoundElement();\n        if (el) {\n            $uxDocQuery('#' + el).css('display', '');\n        }\n    },\n    _createNoMatchFoundElement : function() {\n        var divEle = $uxDocQuery('<div/>', {\n            id: this._getIdOfNoMatchFoundElement(),\n            css: {\n                display: 'none'\n            }\n        });\n        divEle.appendTo($uxDocQuery(this.filterEl));\n        divEle.html(this.txtNoMatchFound);\n    },\n    filterList : function(searchPhrase) {\n        var matchesFound = false;\n        for (var i = 0; i < this.searchIndex.length; i++) {\n            this.storeNodeMatch(this.searchIndex[i], searchPhrase)\n\n            if (this._nodeMatch(this.searchIndex[i], searchPhrase) || this._matchAbove(this.searchIndex[i])) {\n                matchesFound = true;\n                this._showNode(this.searchIndex[i]);\n            } else {\n                this._hideNode(this.searchIndex[i]);\n            }\n        }\n\n        return matchesFound;\n    },\n\n    filterTable : function(searchPhrase) {\n        var matchesFound = false;\n        for (var i = 0; i < this.searchIndex.length; i++) {\n            if (this._nodeMatch(this.searchIndex[i], searchPhrase)) {\n                matchesFound = true;\n                this._showNode(this.searchIndex[i]);\n            } else {\n                this._hideNode(this.searchIndex[i]);\n            }\n        }\n        return matchesFound;\n    }\n}"
          },
