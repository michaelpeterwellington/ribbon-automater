g);background-size:contain;padding:20px;background-color:#e6e6e6;background-repeat:no-repeat;background-position:center}div.infoTag{display:inline;position:absolute;background:#59d6e3;border-radius:10px;left:20%;top:4%;line-height:2;font-size:11px}\ndiv.DeleteToolbarButton{background:url('/images/icons/close.png') -33px -47px;height:16px;width:16px;display:inline-block;background-size:contain}span.FieldGroupTitleSpan{margin-right:auto;margin-left:auto;line-height:22px;padding-left:35px;padding-right:35px}\nTD.FieldGroup{height:100%;padding-bottom:6px;padding-right:5px}a.CompanyLogo{outline:0;padding-left:8px;position:relative;float:left;padding-bottom:5px}a.ActiveActionButton{opacity:1.0}a.InactiveActionButton{opacity:.4}\nspan.CompanyLogo{border:0;background:url('/images/companyLogo2.png') no-repeat;width:120px;height:60px;display:block;margin-bottom:2px}span.TitleHelp{border-style:none;float:right;margin-top:2px;margin-right:2px}\ndiv.FieldGroupContent{font-size:12px;font-family:\"Segoe UI\",Arial,sans-serif;font-style:normal;padding:12px 0 10px 0}div.FieldGroupExpandCollapseEnabled{font-size:12px;font-family:\"Segoe UI\",Arial,sans-serif;font-style:normal;display:none;padding:12px 0 10px 0}\nspan.ActiveGuidance{opacity:1}TR.FormRow #Tasks_SyncProgress-FieldGroup{height:100%;background-color:#d3d3d3;border:0;box-shadow:none;padding:initial}TR.FormRow #Diagnostics_SyncProgress-FieldGroup{height:100%;background-color:#d3d3d3;border:0;box-shadow:none;padding:initial}\nTR.DisabledRow{opacity:.5}TR.EnabledRow{opacity:1.0}TR.ActiveGuidance{opacity:1}TR.ActiveGuidance img span{opacity:1}TR.InActiveGuidance{opacity:.2}TR.InActiveGuidance img span{opacity:.2}TD.FormName{text-align:right;padding-right:10px!important;padding-top:1px!important;padding-bottom:1px!important;font-weight:normal;color:black}\nTD.FormColumn{border:solid 2px #ccc;vertical-align:top}TD.FormValue{font-size:11px;font-family:\"Segoe UI\",Arial,sans-serif;font-weight:normal;font-style:normal;font-variant