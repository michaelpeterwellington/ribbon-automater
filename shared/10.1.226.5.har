            "mimeType": "text/html",
            "text": "\n\n\n\n\n\n\n<script type=\"text/javascript\" language=\"JavaScript\" src=\"/javascript/13.0.0-37_rel_views.js\"></script>\n<script type=\"text/javascript\" language=\"javascript\">\ndocument.onkeypress = sonusUIKeyPress;</script>\n<table class=\"Title TitleBottomBorder\">\n<tr>\n  <td class=\"TitleCol1\"><script>\n    \tfunction hideWarning() {\n      \t\tvar warningMessage = document.getElementById('warningId');\n      \t\twarningMessage.style.display = 'none';\n    \t}\n  \t\t</script>Upload Software to SBC Edge</td>\n  <td class=\"TitleCol2\"><span style=\"padding-right: 5px;\">February 27, 2026 09:17:21</span></td>  <td class=\"TitleCol2\" style=\"width:26px\"><span style=\"padding-right: 6px;\"><a target=\"help\" href=\"http%3A%2F%2Fdoc.rbbn.com%2Fdisplay%2FUXDOC130%2FInstalling+and+Commissioning+the+SBC+Edge+and+SBC+SWe+Lite\" onClick=\"popupHelpWindow('http%3A%2F%2Fdoc.rbbn.com%2Fdisplay%2FUXDOC130%2FInstalling+and+Commissioning+the+SBC+Edge+and+SBC+SWe+Lite');return false;\" ><span class=\"HelpImage\" title=\"Help\" id=\"titleHelp\"></span></a></span></td>\n</tr>\n</table>\n\n<div class=\"Section\">\n<form autocomplete=\"off\";style=\"padding-top:0px; margin-top:0px;\" name=\"Tasks_popup\" enctype=\"multipart/form-data\" method=\"post\" action=\"\" onSubmit=\"document.MM_returnValue=true; trimAllTextFields('Tasks_popup');doBackupOrUpgrade(getContainingFormByName('OKButton')); return document.MM_returnValue != false;\">\n<div class=\"SectionBody\"><table border=\"0\"><tbody>\n<input type=\"hidden\" name=\"nestingLevel\" value=\"0\"/>\n<input type=\"hidden\" name=\"cfg\" value=\"/views/system/codeUploadTask.xml\"/>\n<input type=\"hidden\" id = \"Tasks_type-Hidden\" name=\"type\" value=\"Partition\"/>\n<input type=\"hidden\" name=\"treeNodeID\" value=\"\"/>\n<input type=\"hidden\" name=\"refreshFullTree\" value=\"false\"/>\n<input type=\"hidden\" name=\"openerNavigationContext\" value=\"\"/>\n<tr><td>\n<input type=\"hidden\" name=\"downloadType\" value=\"1\" id=\"Tasks_downloadType-Hidden\">\n<input type=\"hidden\" name=\"mask\" value=\"runtime\" id=\"Tasks_mask-Hidden\">\n<input type=\"hidden\" name=\"Partition\" value=\"3\" id=\"Tasks_Partition-Hidden\">\n<input type=\"hidden\" name=\"setActive\" value=\"true\" id=\"Tasks_setActive-Hidden\">\n<input type=\"hidden\" name=\"action\" value=\"codeUpload\" id=\"Tasks_action-Hidden\">\n<input type=\"hidden\" name=\"asmVersion\" value=\"Not Installed\" id=\"Tasks_asmVersion-Hidden\">\n<input type=\"hidden\" name=\"backupState\" value=\"\" id=\"Tasks_backupState-Hidden\">\n<input type=\"hidden\" name=\"Passphrase\" value=\"\" id=\"Tasks_Passphrase-Hidden\">\n<input type=\"hidden\" name=\"operation\" value=\"0\" id=\"Tasks_operation-Hidden\">\n<input type=\"hidden\" name=\"platformType\" value=\"VSBCE\" id=\"Tasks_platformType-Hidden\">\n<input type=\"hidden\" name=\"fsWare\" value=\"Software\" id=\"Tasks_fsWare-Hidden\">\n<input type=\"hidden\" name=\"HA\" value=\"1\" id=\"Tasks_HA-Hidden\">\n<input type=\"hidden\" name=\"hastandalone\" value=\"0\" id=\"Tasks_hastandalone-Hidden\">\n<input type=\"hidden\" name=\"MAX_FILE_SIZE\" value=\"134217728\" id=\"Tasks_MAX_FILE_SIZE-Hidden\">\n<table class=\"DialogForm\" border=\"0\">\n  <tr id=\"Tasks_Backup-Row\" class=\"FormRow\" valign=\"top\">\n<td class=\"FieldGroup\" colspan=\"3\" id=\"Tasks_UpgradeStepOne\">\n<div id=\"Tasks_UpgradeStepOne-FieldGroup\" class=\"FieldGroup\">\n<div class=\"FieldGroupTitle\"><span class=\"FieldGroupTitleSpan\">Step 1: Backup Configuration</span></div>\n<div id=\"Tasks_UpgradeStepOne-FieldGroupContent\" class=\"FieldGroupContent\" style=\"visibility: visible;\">\n<table class=\"lowSpacedTable\"><tbody>\n  <tr class=\"FormRow\">\n    <td class=\"FormName\"></td>\n    <td class=\"FormValue\"><span class=\"readonly\"></span></td><td></td>\n  </tr>\n  <tr class=\"FormRow\">\n    <td class=\"FormLabel\" colspan=2>\n<table class=\"SingleColumnField\"><tr><td></td></tr></table></td>\n  </tr>\n  <tr id=\"Tasks_backupPassphraseEleRow-Id\" class=\"FormRow\">\n    <td class=\"FormName\"><a title=\"\nIf passphrase is left blank, the configuration may be restored to this node. All passwords will be lost when the configuration is restored to a different node.\n\nIf the passphrase is provided, the configuration may be restored to any node preserving all the configured passwords, as long as the same passphrase is provided during the restore operation.\";\n\t\t\t\t\t\t\" style=\"cursor:help;\">Passphrase</a></td>\n    <td class=\"FormValue\"><div  id=\"Tasks_backupPassphrase-Div\" class=\"Unedited-text\"><span id=\"Tasks_backupPassphrase-Span\" class=\"Unedited-text\"><input type=\"password\" style=\"width: 195px;\" id=\"Tasks_backupPassphrase-Field\" class=\"Unedited-text\" title=\"\nIf passphrase is left blank, the configuration may be restored to this node. All passwords will be lost when the configuration is restored to a different node.\n\nIf the passphrase is provided, the configuration may be restored to any node preserving all the configured passwords, as long as the same passphrase is provided during the restore operation.\";\n\t\t\t\t\t\t\" name=\"backupPassphrase\" onkeyup=\"javascript:wrapperEventFunction('Tasks', 'Tasks_backupPassphrase-Field'); highlightChangedField('backupPassphrase', event);\">\n<span id =\"Tasks_backupPassphrase-Field-eyeSpan\" onmousedown=\"passwordMouseDown('Tasks_backupPassphrase-Field')\" onmouseup=\"passwordMouseUp('Tasks_backupPassphrase-Field')\" class=\"PasswordEye\"></span></span>&nbsp;<span class=\"details\">optional, max 128 chars.</span></div>\n</td><td></td>\n  </tr>\n  <tr id=\"Tasks_confirmBackupPassphraseEleRow-Id\" class=\"FormRow\">\n    <td class=\"FormName\">Confirm Passphrase</td>\n    <td class=\"FormValue\"><div  id=\"Tasks_confirmBackupPassphrase-Div\" class=\"Unedited-text\"><span id=\"Tasks_confirmBackupPassphrase-Span\" class=\"Unedited-text\"><input type=\"password\" style=\"width: 195px;\" id=\