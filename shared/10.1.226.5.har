(k.value)||Number(k.value)<1||Number(k.value)>8){c+=\"\\n - Monitoring Interval Field value must be between 1 and 8.\"\n}}if(f.value.length==0){c+=\"\\n - E911 Message Field is mandatory.\"}for(var e=0;e<d.options.length;e++){if(j.value!=\"\"){j.value+=\",\"+d.options[e].value}else{j.value=d.options[e].value}}if(d.options.length==0){c+=\"\\n - Recipients List is mandatory and must have at least one entry.\"\n}if(c.length>0){alert(\"The following errors were found:\\n\"+c);document.MM_returnValue=false}else{document.MM_returnValue=true;if(a.value==\"1\"){alert(\"WARNING : Only one profile should be Active . If there are other profiles active this profile  will not be activated.\")\n}}}function addEmergencyList(){var b=tabNavigationContext.getElementById(\"E911Recipients-Field\");var a=tabNavigationContext.getElementById(\"E911RecipientsList-Field\");var e=false;var g=tabNavigationContext.getElementById(\"E911RecipientsList-Field\");\nvar c=g.options;var d=\"\";if(b){if(b.value==\"\"){d+=\"\\nPhone Number field is empty, it must contain a valid phone number\"}else{if(!(isValidE164(b.value,false))){d+=\"\\nPhone Number contains an invalid value, it must contain a valid E.164 number\"\n}}}if(c.length>5&&!e){d+=\"\\nMaximum recepients allowed per pool is 6. You have reached the limit.\"}if(d==\"\"){if(c.length==1&&g.options[0].value==\"\"){g.options[0]=new Option(b.value)}else{cbValue=b.value;\nfor(i=0;i<c.length;i++){if(g.options[i].value==b.value){if(cbValue.length>5){d+=\"\\nCallback Number '\"+cbValue.substring(0,4)+\"....' is already in the list of numbers. Please add a different one.\"}else{d+=\"\\nCallback Number '\"+cbValue+\"' is already in the list of numbers. Please add a different one.\"\n}e=true}}if(!e){g.options[c.length]=new Option(cbValue);var f=buildMultiSelectValueString(a);if(f!=\"\"){tabNavigationContext.getElementById(\"E911RecipientsList-Field-Remove\").disabled=false}}}highlightChangedFieldWidget(\"E911RecipientsList\")\n}if(d!=\"\"){alert(\"The fo