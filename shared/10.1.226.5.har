            "text": "var initialSetup_publicCloudType=null;var maxNetworkSegmentEntry=21;var maxStaticRoutes=5;function initialSetupIsPublicCloud(){if(initialSetup_publicCloudType===null){if(isPlatformVSBCE()){var a=tabNavigationContext.getElementById(\"__m_IsPublicCloud-Hidden\");\nif(a){initialSetup_publicCloudType=a.value}}}return((initialSetup_publicCloudType!==null)&&(initialSetup_publicCloudType!==\"0\"))}function initSetupForm(){var i=initialSetupIsPublicCloud();if(getContainerType()!=\"1\"){var l=tabNavigationContext.getElementById(\"usePrimaryDNS-Field\");\nvar b=tabNavigationContext.getElementById(\"useSecondaryDNS-Field\");setDNSFieldVisibility(l.value,b.value)}var f=tabNavigationContext.getElementById(\"ifIpAddrAssignMethod-Field\");var g=tabNavigationContext.getElementById(\"useEdgeview-Field\");\nif(getContainerType()!=\"1\"){var j=tabNavigationContext.getElementById(\"configureDefaultRoute-Field\");setGatewayAddressVisibility(j.value)}setTemplateVisibility();if(getContainerType()!=\"1\"){setIfIpAddrAssignMethod(f.value)\n}else{setRowVisibility(\"AdminIPAddressFGRow\",\"\");setRowVisibility(\"adminIpV4Address\",\"\");setRowVisibility(\"adminIpV4Netmask\",\"\");setRowVisibility(\"domainNameRow\",\"\");setRowVisibility(\"DefaultIPRouteFGRow\",\"\");\nsetRowVisibility(\"Ethernet1HR\",\"\");setRowVisibility(\"DNSFGRow\",\"\");setRowVisibility(\"AdditionalStaticRouteFGRow\",\"\");setRowVisibility(\"IPAddressFGRow\",\"\")}setHAIFVisibility();var k=document.getElementById(\"__m_Edge8KChassis-Hidden\");\nif(k.value!=\"1\"){setEdgeviewFieldVisibility(g.value)}if(isVSBCE()){if(i){var c=tabNavigationContext.getElementById(\"adminIpAddrAssignMethod-Hidden\");var d=tabNavigationContext.getElementById(\"eth1IpAddrAssignMethod-Hidden\");\nvar h=tabNavigationContext.getElementById(\"eth2IpAddrAssignMethod-Hidden\");var a=tabNavigationContext.getElementById(\"eth3IpAddrAssignMethod-Hidden\");var e=tabNavigationContext.getElementById(\"eth4IpAddrAssignMethod-Hidden\");\