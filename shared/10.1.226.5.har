          "content": {
            "size": 71990,
            "mimeType": "text/css",
            "text": ".container{border-width:0;overflow:hidden;padding:0;display:none}.inner-layout-container{height:100%}.ui-layout-west,.ui-layout-south,.ui-layout-center{padding-bottom:5px;overflow:auto}input,select,button{margin:0}\ninput[type=text],input[type=textarea],input[type=password],select{box-sizing:border-box;-moz-box-sizing:border-box}DIV.LogicalExpressionConditionRow{padding:1px 0 1px 0}DIV.LogicalExpressionOperatorRow{padding:1px 0 1px 0}\nDIV.LogicalExpressionMain{height:100%;padding:5px 5px 15px 5px}DIV.LogicalExpressionFormButtons{overflow:hidden;padding:0 5px 0 5px}SPAN.LogicalExpressionFormSpacer{display:inline-block}SPAN.LogicalExpressionIndent{display:inline-block;width:30px}\nSPAN.LogicalExpressionFormButtons{float:right;margin-right:25px}.monospaceFontField{font-family:\"Courier New\",Courier,monospace!important}span.BulletPoint{display:block;margin:6px 5px;background-color:#504a50;width:6px;height:6px;border-radius:3px}\nINPUT.InlineDisplayButton{margin:0 2px 0 2px;padding:0 4px 0 4px;border-style:outset;border-width:1px;border-color:#c2c2c2}INPUT.InlineDisplayButton:enabled:hover{opacity:1;background-color:#e6e6e6}INPUT.InlineDisplayButton:disabled{opacity:.25}\nP{font-size:12px;font-family:Verdana,Arial,sans-serif;font-weight:normal;font-style:normal;font-variant:normal}P.CopyrightLink{font-size:11px;font-family:Arial,sans-serif;font-weight:normal;font-style:normal;font-variant:normal;text-align:center}\nSPAN.readonly{color:black;font-size:12px;font-family:\"Segoe UI\",Arial,sans-serif;font-style:normal}SPAN.annotation{font-size:10px;font-style:italic}INPUT{font-family:\"Segoe UI\",Arial,sans-serif;font-weight:normal;font-style:normal;font-variant:normal;font-size:12px}\ninput.TableRowCheckbox{position:relative;top:4px}input.FormSubmitButton{width:65px;height:26px;font:bold 12px Verdana,Arial,sans-serif;color:#FFF;outline:0 none;background-color:#f51581;background:linear-gradient(#f7a0d7,#f0127c 15%,#f51581 45%,#f0127c 85%,#e00d6e 100%);border:1px solid #484b48;border-radius:6px;text-align:center;cursor:pointer}\ninput.DisabledFormSubmitButton{width:65px;height:26px;font:bold 12px Verdana,Arial,sans-serif;color:#FFF;outline:0 none;background-color:#f51581;background:linear-gradient(#808183,#606161 15%,#545454 50%,#545454);border:1px solid #484b48;border-radius:6px;text-align:center;cursor:pointer}\ninput.ModalDialogSubmitButton{width:52px;height:22px;font:bold 11px Verdana,Arial,sans-serif;color:#FFF;outline:0;background-color:#f51581;background:linear-gradient(#f7a0d7,#f0127c 15%,#f51581 45%,#f0127c 85%,#e00d6e 100%);border:1px solid #484b48;border-radius:6px;margin:0 3px 0 3px;text-align:center;cursor:pointer}\n.GreyDialogButton{width:120px;height:26px;font:bold 11px Verdana,Arial,sans-serif;color:#FFF;background-color:#b0b0b0;background:linear-gradient(#d0d0d0,#b0b0b0 15%,#b0b0b0 45%,#a0a0a0 85%,#909090 100%);border:1px solid #484b48;border-radius:6px;margin:5px 3px;text-align:center;cursor:pointer;transition:background .3s ease}\n.GreyDialogButton:hover{background:linear-gradient(#e0e0e0,#c0c0c0 15%,#b0b0b0 45%,#a0a0a0 85%,#909090 100%)}.GreyDialogButton:active{background:linear-gradient(#b0b0b0,#a0a0a0 15%,#909090 45%,#808080 85%,#707070 100%)}\ninput.FormSubmitButton:hover,input.ModalDialogSubmitButton:hover{background-color:#f63191;background:linear-gradient(#f9bde3,#f2318e 15%,#f63191 45%,#f2318e 85%,#f2187d 100%)}input.FormCancelButton,input.ModalDialogCancelButton{background-color:#4b4b4b;background:linear-gradient(#666,#434343 15%,#4b4b4b 45%,#434343 85%,#2f2f2f 100%)}\ninput.FormCancelButton:hover,input.ModalDialogCancelButton:hover{background-color:#5c5c5c;background:linear-gradient(#787878,#545454 15%,#5c5c5c 45%,#545454 85%,#404040 100%)}input.FormQueryButton{background-color:#828282;background:linear-gradient(#b0b0b0,#777 15%,#828282 45%,#777 85%,#6f6f6f 100%);border:3px solid #7e00b9}\ninput.FormQueryButton:hover{background-color:#8f8f8f;background:linear-gradient(#b7b7b7,#7f7f7f 1