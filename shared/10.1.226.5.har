            "text": "MOTypes=function(){};MOTypes={MO_TYPE_DS1_E1_PORT:\"0\",MO_TYPE_DS1_T1_PORT:\"1\",MO_TYPE_FXS_PORT:\"2\",MO_TYPE_FXO_PORT:\"3\",MO_TYPE_BRI_PORT:\"4\",MO_TYPE_DS1_CHANNEL:\"1\",MO_TYPE_SIP_CHANNEL:\"2\",MO_TYPE_FXS_CHANNEL:\"3\",MO_TYPE_FXO_CHANNEL:\"4\",MO_TYPE_BRI_CHANNEL:\"5\",MO_TYPE_SIP_SG:\"1\"};\nvar BMPStatusCode={VALIDATION_RESPONSE:\"121\",CARD_STATUS:\"211\",PORT_STATUS:\"212\",CHAN_STATUS:\"213\",SG_STATUS:\"214\",CFG_STATUS:\"220\",ALARM:\"221\",VERSION:\"222\",DISCONNECT:\"229\",ANALOG_LED:\"300\",ANALOG_CARD:\"301\",ANALOG_CHANNEL:\"302\",SESSION_INFO:\"400\",ERROR_TOO_MANY_SESSIONS:\"421\",SESSION_EXPIRY:\"554\"};\nvar BMPSGType={ISDN:\"0\",SIP:\"1\",CAS:\"2\"};var BMPDS1SignalingType={ISDN:\"0\",CAS:\"1\"};var BMPObjectType={VALIDATION:\"-2\",UNKNOWN:\"-1\",NONE:\"0\",CARD:\"1\",PORT:\"2\",CHAN:\"3\",SIP_SG:\"4\",ISDN_SG:\"5\",CAS_SG:\"6\",A_CARD:\"7\",A_LED:\"8\",A_CHANNEL:\"9\",};\nvar BMPUpdateType={UNKNOWN:-1,NONE:0,STATUS:1,CONFIG:2,ALARM:3};var BMPConfigAction={MODIFY:0,ADD:1,REMOVE:2};AdminState=function(){};AdminState={DISABLED:0,ENABLED:1,DRAIN:2};PortAlarmState=function(){};\nPortAlarmState={PORT_AS_YELLOW:1,PORT_AS_BLUE:2,PORT_AS_REDLOS:3,PORT_AS_REDLOF:4,PORT_AS_PASSTHRU:5};ChannelStatus=function(){};ChannelStatus={CHS_CONNECTED:10,CHS_UNKNOWN:20,CHS_PASSTHRU:21};CallType=function(){};\nCallType={CT_UNSET:0,CT_VOICE:1,CT_T38FAX:2,CT_STU:3,CT_MODEM:4,CT_UNCOMPRESSED_PCM:5,CT_SECURE_MEDIA_IB_ONLY:6,CT_SECURE_MEDIA_OB_ONLY:7,CT_SECURE_MEDIA_IB_AND_OB:8,CT_SECURE_MEDIA_PASSTHROUGH:9,CT_DATA:10,CT_FAX_PASSTHROUGH:11,CT_MODEM_PASSTHROUGH:12};\nvar SG_TOKEN=\"32821\";var Alarm_cleared=3;var Alarm_generated=2;function BMPMessageDecoder(b,c,a){this.model=c;this.controller=a;this.monitor=b}BMPMessageDecoder.prototype.extractSessionID=function(c){var a=this.extractAVPairs(c);\nfor(var b=0;b<a.length;b++){if(a[b][0]==\"sessionId\"){return a[b][1]}}return null};BMPMessageDecoder.prototype.handleMessage=function(a){var c=new Array();var h=trim(a).split(\"\\n\");for(var e=0;e<h.length;\ne++){var f=h[e];var b=f.indexOf(\" \");if(b>0){var d=f.substr(0,b);f=trim(f.substr((b+1)));var g=this.decodeObject(d,f,false);if(g!=null){c.push(g)}else{monitorDbg(\"ERROR: GOT UNRECOGNIZED RESPONSE CODE \"+d+\", STRING WAS \"+f+\"\\n\")\n}}else{monitorDbg(\"ERROR: GOT MALFORMED BMP MESSAGE LINE: \"+f+\"\\n\")}}return c};BMPMessageDecoder.prototype.decodeObject=function(d,g,f){var c;var b;switch(d){case BMPStatusCode.VALIDATION_RESPONSE:c=this.decodeValidation(g);\nbreak;case BMPStatusCode.CARD_STATUS:b=this.extractAVPairs(g);c=this.decodeCard(b,f);if(c!=null){c.bmpUpdateType=BMPUpdateType.STATUS}break;case BMPStatusCode.PORT_STATUS:b=this.extractAVPairs(g);c=this.decodePort(b,f);\nif(c!=null){c.bmpUpdateType=BMPUpdateType.STATUS}break;case BMPStatusCode.CHAN_STATUS:b=this.extractAVPairs(g);c=this.decodeChannel(b);if(c!=null){c.bmpUpdateType=BMPUpdateType.STATUS}break;case BMPStatusCode.ANALOG_LED:b=this.extractAVPairs(g);\nc=this.decodeAnalogLed(b,f);if(c!=null){c.bmpUpdateType=BMPUpdateType.STATUS}break;case BMPStatusCode.ANALOG_CHANNEL:b=this.extractAVPairs(g);c=this.decodeAnalogChannel(b,f);if(c!=null){c.bmpUpdateType=BMPUpdateType.STATUS\n}break;case BMPStatusCode.ANALOG_CARD:b=this.extractAVPairs(g);c=this.decodeAnalogCard(b,f);if(c!=null){c.bmpUpdateType=BMPUpdateType.STATUS}break;case BMPStatusCode.SG_STATUS:b=this.extractAVPairs(g);\nvar a=null;var e=0;while((a==null)&&(e<b.length)){if(b[e][0]==\"T\"){a=b[e][1];if(a==BMPSGType.ISDN){a=BMPObjectType.ISDN_SG}else{if(a==BMPSGType.SIP){a=BMPObjectType.SIP_SG}else{if(a==BMPSGType.CAS){a=BMPObjectType.CAS_SG\n}}}}e++}if(a!=null){c=this.decodeSG(b,a,f);if(c!=null){c.bmpUpdateType=BMPUpdateType.STATUS}}break;case BMPStatusCode.CFG_STATUS:c=this.decodeConfigChange(g);if(c!=null){c.bmpUpdateType=BMPUpdateType.CONFIG\n}break;case BMPStatusCode.ALARM:c=this.decodeAlarm(g);if(c!=null){c.bmpUpdateType=BMPUpdateType.ALARM}break;case BMPStatusCode.ERROR_TOO_MANY_SESSIONS:c=null;reportMonitorError(MonitorErrorLevel.FATAL,MonitorErrorCode.ERROR_TOO_MANY_SESSIONS);\nbreak;default:c=null;break}return c};BMPMessageDecoder.prototype.decodeValidation=function(e){var d=new Object();d.bmpType=BMPObjectType.NONE;var a=this.extractAVPairs(e);var b=false;for(var c=0;c<a.length;\nc++){switch(a[c][0]){case\"S\":d.S=a[c][1];b=(d.S==\"1\");break}}if(b==false){reportMonitorError(MonitorErrorLevel.FATAL,MonitorErrorCode.ERROR_INVALID_SESSION);return d}return d};BMPMessageDecoder.prototype.decodeCard=function(a,f){var c=new Object();\nc.bmpType=BMPObjectType.CARD;c.cardType=c.status=0;for(var d=0;d<a.length;d++){switch(a[d][0]){case\"OID\":var e=a[d][1].split(\".\");var g=e.length;c.rowID=e[(g-1)];c.pk=MonitorModel.createCardPK(c);break;\ncase\"rowID\":c.rowID=a[d][1];c.pk=MonitorModel.createCardPK(c);break;case\"CT\":case\"CardType\":c.cardType=a[d][1];break;case\"S\":case\"Status\":c.status=a[d][1];break}}var b=null;if(!f){b=this.model.getCardObject(c.rowID);\nif(b){this.model.updateCardRTStatus(b,c.cardType,c.status)}else{c.portCount=0;this.model.addCard(c);b=c}}else{c.portCount=0;this.model.addCard(c);b=c}if(!f){if(b){this.controller.cardChange(b,0)}else{monitorDbg(\"BMPDecoder.decodeCard: Not found or create card for  \"+c.rowID)\n}}return c};BMPMessageDecoder.prototype.decodeAnalogCard=function(b,e){var f=new Object();f.bmpType=BMPObjectType.A_CARD;f.cardType=f.led=0;for(var d=0;d<b.length;d++){switch(b[d][0]){case\"rowID\":case\"RW\":f.rowID=b[d][1];\nf.pk=MonitorModel.createAnalogCardPK(f);break;case\"CardType\":case\"CT\":f.cardType=b[d][1];break;case\"LedCount\":case\"LC\":f.ledcount=b[d][1];break}}f.led=24;var a=f.cardType;if(a==AnalogPortTypes.PORT_TYPE_PRI){f.portCount=f.led\n}else{f.portCount=0}var c=null;if(!e){c=this.model.getAnalogCardObject(f.rowID);if(c){}else{this.model.addAnalogCard(f);c=f}}else{this.model.addAnalogCard(f);c=f}return f};BMPMessageDecoder.prototype.decodeAnalogLed=function(a,e){var d=new Object();\nd.alarms={};d.signalingType=-1;d.physicalType=d.loopbackType=d.alarmStatus=d.adminState=0;d.bmpType=BMPObjectType.A_LED;d.operStatus=0;d.description=\"\";for(var c=0;c<a.length;c++){switch(a[c][0]){case\"rowID\":d.rowID=a[c][1];\nbreak;case\"ConfigIEState\":d.adminState=a[c][1];break;case\"parentID\":d.parentID=a[c][1];break;case\"LedStatus\":d.LedStatus=a[c][1];break}}d.cardID=-1;d.portID=-1;d.pk=MonitorModel.createledPK(d);var b=this.model.getAnalogCardObject(d.parentID);\nif(!b){monitorDbg(\"Could not find card for the port \"+d.parentID);return null}var f=this.model.getCardLedObject(d.parentID,d.rowID);if(!f){var b=this.model.getAnalogCardObject(d.parentID);if(b){if(b.cardType==AnalogPortTypes.PORT_TYPE_PRI){d.channelType=AnalogChannelType.PRI_CHANNEL_TYPE\n}else{if(b.cardType==AnalogPortTypes.PORT_TYPE_FXS){d.channelType=AnalogChannelType.FXS_CHANNEL_TYPE}else{if(b.cardType==AnalogPortTypes.PORT_TYPE_FXO){d.channelType=AnalogChannelType.FXO_CHANNEL_TYPE}}}}this.model.addLedForCard(d,d.parentID)\n}else{this.model.updateLedRTStatus(f,d.LedStatus)}f=this.model.getCardLedObject(d.parentID,d.rowID);if(f){var b=this.model.getAnalogCardObject(d.parentID);this.model.updateLedRuntimeStatus(f,d.LedStatus);\nif(b.cardType==AnalogPortTypes.PORT_TYPE_PRI){this.controller.portChange(d,BMPConfigAction.MODIFY)}else{this.controller.ledChange(f,d.LedStatus)}}return d};BMPMessageDecoder.prototype.decodeAnalogChannel=function(a){var f=new Object;\nf.bmpType=BMPObjectType.CHAN;f.signalingType=-1;for(var c=0;c<a.length;c++){switch(a[c][0]){case\"OID\":var e=a[c][1];oidArray=a[c][1].split(\".\");oidLen=oidArray.length;f.rowID=oidArray[(oidLen-1)];if(oidArray[(oidLen-3)]==1){f.portID=oidArray[(oidLen-2)]\n}else{if(oidArray[(oidLen-3)]==2){if(oidArray[(oidLen-2)]==1){f.portID=6}else{if(oidArray[(oidLen-2)]==2){f.portID=7}else{f.portID=8}}}else{if(oidArray[(oidLen-2)]==1){f.portID=4}else{if(oidArray[(oidLen-2)]==2){f.portID=5\n}}}}f.cardID=oidArray[(oidLen-4)];f.parentID=oidArray[(oidLen-3)]+\".\"+oidArray[(oidLen-2)];f.sgID=-1;f.pk=MonitorModel.createChannelPK(f);break;case\"CallStatus\":if(a[c][1]==99){f.status=4}else{f.status=a[c][1]\n}break;case\"CD\":f.channelDirection=a[c][1];break}}f.enabled=1;var d=null;d=this.model.getChannelObject(f.cardID,f.portID,f.rowID);if(!d){var b=this.model.getAnalogCardObject(f.cardID);if(b){if(b.cardType==AnalogPortTypes.PORT_TYPE_PRI){f.channelType=AnalogChannelType.PRI_CHANNEL_TYPE\n}else{if(b.cardType==AnalogPortTypes.PORT_TYPE_FXS){f.channelType=AnalogChannelType.FXS_CHANNEL_TYPE}else{if(b.cardType==AnalogPortTypes.PORT_TYPE_FXO){f.channelType=AnalogChannelType.FXO_CHANNEL_TYPE}}}}var g=this.model.getCardLedObject(f.cardID,f.portID);\nif(g){this.model.addChannelForLed(f,g)}else{monitorDbg(\"BMPMessageValidator.decodeChannel: Port for Channel not found with key: \"+f.cardID+\".\"+f.portID)}}else{this.model.updateChannelRuntimeStatus(d,f.status);\nthis.controller.analogchannelChange(d)}this.controller.analogchannelChange(d);return f};BMPMessageDecoder.prototype.decodePort=function(o,m){var q=new Object();q.alarms={};q.signalingType=-1;q.physicalType=q.loopbackType=q.alarmStatus=q.adminState=0;\nq.bmpType=BMPObjectType.PORT;q.operStatus=0;q.description=\"\";for(var k=0;k<o.length;k++){switch(o[k][0]){case\"OID\":var s=o[k][1].split(\".\");var h=s.length;q.rowID=s[(h-1)];q.parentID=s[(h-2)];break;case\"rowID\":q.rowID=o[k][1];\nbreak;case\"parentID\":q.parentID=o[k][1];break;case\"ConfigIEState\":q.adminState=o[k][1];break;case\"OS\":q.operStatus=o[k][1];break;case\"AS\":case\"PortAlarmStatus\":q.alarmStatus=o[k][1];break;case\"LBS\":case\"PortLoopbackType\":q.loopbackType=o[k][1];\nbreak;case\"PortPhysicalType\":q.physicalType=o[k][1];break;case\"SignalingType\":case\"ST\":q.signalingType=o[k][1];break;case\"PortDescription\":q.description=o[k][1];break}}q.pk=MonitorModel.createPortPK(q);\nif(m){var f=this.model.getCardObject(q.parentID);if(!f){monitorDbg(\"Could not find card for the port \"+q.pk);return null}this.model.addPort(q);this.model.updatePortCount(f);var l=this.model.getChannelsForObject(q);\nif(l.length==0){q.numChannels=this.model.portChannelCount(q.physicalType);for(var k=1;k<=q.numChannels;k++){var d=new Object;d.rowID=k;d.parentID=q.pk;d.cardID=q.parentID;d.portID=q.rowID;d.sgID=-1;d.pk=MonitorModel.createChannelPK(d);\nd.channelType=MonitorModel.getChannelType(q.physicalType);d.enabled=q.adminState;if(q.alarmStatus==PortAlarmState.PORT_AS_PASSTHRU){d.status=ChannelStatus.CHS_PASSTHRU}else{d.status=q.operStatus}d.signalingType=q.signalingType;\nthis.model.addChannelForPort(d,q)}}return q}else{var r=this.controller;var c=this.model.getPortObject(q.parentID,q.rowID);if(!c){monitorDbg(\"Could not find port - \"+q.pk+\" adding it to the model\");this.model.addPort(q);\nf=this.model.getCardObject(q.parentID);if(f){this.model.updatePortCount(f)}}else{this.model.updatePortRTStatus(q.pk,q.operStatus,q.alarmStatus,q.loopbackState);q=this.model.getPortObject(q.parentID,q.rowID);\nif(!q){monitorDbg(\"Port could not be found \")}}monitorDbg(\"processPort before port chage operstatus: \"+q.operStatus);r.portChange(q,BMPConfigAction.MODIFY);monitorDbg(\"processPort before ch chnge: \"+q.pk);\nvar e=q.numChannels;var b=q.physicalType;if(b==PortTypes.PORT_TYPE_E1){e=PortChannelCount.E1_CHANNELS_COUNT}else{if(b==PortTypes.PORT_TYPE_T1){e=PortChannelCount.T1_CHANNELS_COUNT}else{if(b==PortTypes.PORT_TYPE_FXS){e=PortChannelCount.FXS_CHANNELS_COUNT\n}else{if(b==PortTypes.PORT_TYPE_FXO){e=PortChannelCount.FXO_CHANNELS_COUNT}else{if(b==PortTypes.PORT_TYPE_BRI){e=PortChannelCount.BRI_CHANNELS_COUNT}else{monitorDbg(\"Runtime BMPMessageDecoder.decodePort:ERROR: Port Type Unknown: \"+b)\n}}}}}if(q.operStatus==1){var a=q.adminState;var p=(q.operStatus==0)?1:0;for(var g=0;g<e;g++){var n=this.model.getChannelObject(q.parentID,q.rowID,g+1);if(n){if(!(this.model.isDChannel(q,n.rowID))){p=0}else{p=16;\nmonitorDbg(\"BMPMessageDecoder.decodePort Runtime: processPort D-channel \"+p)}this.model.updateChannelConfigStatus(n,a);p=(q.alarmStatus==PortAlarmState.PORT_AS_PASSTHRU)?ChannelStatus.CHS_PASSTHRU:p;this.model.updateChannelRuntimeStatus(n,p);\nr.channelChange(this.model.getChannelByPK(n.pk))}else{monitorDbg(\"Runtime: BMPMessageDecoder.decodePort: Channel not found for \"+q.pk+\".\"+g)}}}}return q};BMPMessageDecoder.prototype.decodeChannel=function(j){var a=new Object;\na.bmpType=BMPObjectType.CHAN;for(var f=0;f<j.length;f++){switch(j[f][0]){case\"OID\":var c=j[f][1];if(c.indexOf(SG_TOKEN)>-1){a.cardID=-1;a.portID=-1;var k=j[f][1].split(\".\");var e=k.length;a.rowID=k[(e-1)];\na.parentID=k[(e-2)];a.sgID=a.parentID;a.pk=MonitorModel.createSGChannelPK(a.sgID,a.rowID)}else{k=j[f][1].split(\".\");e=k.length;a.rowID=k[(e-1)];a.portID=k[(e-2)];a.cardID=k[(e-3)];a.parentID=k[(e-3)]+\".\"+k[(e-2)];\na.sgID=-1;a.pk=MonitorModel.createChannelPK(a)}break;case\"E\":a.enabled=j[f][1];break;case\"S\":a.status=j[f][1];break;case\"CD\":a.channelDirection=j[f][1];break;case\"CCD\":a.callDirection=j[f][1];break;case\"CSN\":a.callCSN=j[f][1];\nbreak;case\"CT\":a.callType=j[f][1];break;case\"SG\":a.sg=j[f][1];break}}var h=null;if(a.sgID==-1){h=this.model.getChannelObject(a.cardID,a.portID,a.rowID);if(!h){var b=this.model.getPortObject(a.cardID,a.portID);\nif(b){a.channelType=MonitorModel.getChannelType(b.physicalType);this.model.addChannelForPort(a,b)}else{monitorDbg(\"BMPMessageValidator.decodeChannel: Port for Channel not found with key: \"+a.cardID+\".\"+a.portID)\n}}else{b=this.model.getPortObject(h.cardID,h.portID);this.model.setSignalingType(h,b.signalingType);if(!(this.model.isDChannel(b,h.rowID))){this.model.updateChannelBulkRTStatus(h,a.status,a.callDirection,a.channelDirection,0,a.callCSN,a.sgID,a.callType)\n}else{var d=(a.status==0||a.status==16)?16:15;this.model.updateChannelRuntimeStatus(h,d)}h=this.model.getChannelObject(a.cardID,a.portID,a.rowID)}this.controller.channelChange(h)}else{h=this.model.getSGChannelObject(a.sgID,a.rowID);\nif(!h){var g=this.model.getSGObj