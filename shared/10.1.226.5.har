            "text": "INPUT.InlineDisplayButton{border-radius:3px 5px 3px 5px}INPUT.InlineDisplayButton:enabled:hover{border-radius:3px 3px 3px 3px}TD{font-size:11px;font-family:Verdana,Arial,sans-serif;font-style:normal;font-variant:normal}\nspan.Edited-enum{height:100%;display:inline-block}select.Edited-enum{border-style:solid;border-width:2px;border-color:#06f}span.Edited-checkbox{border-style:solid;border-width:2px;border-color:#06f;width:24px;height:23px;display:inline-block}\nspan.Edited-text{height:100%;display:inline-block}input.Edited-text{border-style:solid;border-width:2px;border-color:#06f}span.Edited-password{height:100%;display:inline-block}input.Edited-password{border-style:solid;border-width:2px;border-color:#06f}\nspan.Edited-textarea{height:100%;display:inline-block}textarea.Edited-textarea{border-style:solid;border-width:2px;border-color:#06f}span.Edited-radio{border-style:solid;border-width:2px;border-color:#06f;height:24px;display:inline-block}\nspan.Edited-filebrowser{height:100%;display:inline-block}span.Unedited-enum{height:100%;display:inline-block}span.Unedited-checkbox{border-style:hidden;border-width:1px;border-color:#06f;width:20px;height:21px;display:inline-block}\nspan.Unedited-text{height:100%;display:inline-block}span.Unedited-password{height:100%;display:inline-block}span.Unedited-textarea{height:100%;display:inline-block}span.Unedited-radio{border-style:hidden;border-width:1px;border-color:#06f;height:28px;display:inline-block}\nspan.Unedited-filebrowser{height:100%;display:inline-block}DIV.TableDetailsDiv{width:99%}TR.TableRowHdr{height:30px}TR.TableRowLinks0{padding-bottom:6px}TR.TableRowLinks0Selected{box-shadow:inset 0 3px 4px rgba(100,100,100,0.8)}\nTR.TableRowLinks0:hover,TR.TableRowLinks0:active{box-shadow:inset 0 3px 4px rgba(100,100,100,0.8)}TR.TableRowLinks1{padding-bottom:6px}TR.TableRowLinks1Selected{box-shadow:inset 0 3px 4px rgba(100,100,100,0.8)}\nTR.TableRowLinks1:hover,TR.TableRowLinks1:active{box-shadow:inset 0 3px