tion usePrimaryDNSUpdated(){var b=tabNavigationContext.getElementById(\"usePrimaryDNS-Field\");var a=tabNavigationContext.getElementById(\"useSecondaryDNS-Field\");\nsetDNSFieldVisibility(b.value,a.value)}function useSecondaryDNSUpdated(){var b=tabNavigationContext.getElementById(\"usePrimaryDNS-Field\");var a=tabNavigationContext.getElementById(\"useSecondaryDNS-Field\");\nsetDNSFieldVisibility(b.value,a.value)}function ifIpAddrAssignMethodUpdated(){var a=tabNavigationContext.getElementById(\"ifIpAddrAssignMethod-Field\");setIfIpAddrAssignMethod(a.value)}function setGatewayAddressVisibility(b){var a=tabNavigationContext.getElementById(\"gatewayAddressRow\");\nif(b==\"1\"){a.style.display=\"\"}else{a.style.display=\"none\"}}function setTemplateVisibility(){var e=tabNavigationContext.getElementById(\"templateReq-Field\");var c=tabNavigationContext.getElementById(\"templateAreaRow\");\nvar a=tabNavigationContext.getElementById(\"managementInterfaceFieldGroupRow\");var f=tabNavigationContext.getElementById(\"localUserRow\");var d=tabNavigationContext.getElementById(\"staticRouteRow\");var b=initialSetupIsPublicCloud();\nif(b&&e&&e.value==1){c.style.display=\"\";if(f){f.style.display=\"none\"}if(getContainerType()!=\"1\"){a.style.display=\"none\";d.style.display=\"none\"}}else{c.style.display=\"none\";if(f){f.style.display=\"\"}if(getContainerType()!=\"1\"){a.style.display=\"\";\nd.style.display=\"\"}}}function setEth1IfVisibility(b,g){var a=tabNavigationContext.getElementById(\"ipV4Address\");var f=tabNavigationContext.getElementById(\"ipV4Netmask\");var i=tabNavigationContext.getElementById(\"eth1NextHopRow\");\nvar h=tabNavigationContext.getElementById(\"Eth1IPV4AddrAzuredRow\");var d=tabNavigationContext.getElementById(\"Eth1IPV4AddrMaskAzureRow\");var c=tabNavigationContext.getElementById(\"Eth1IPV4AddrAwsRow\");\nvar e=tabNavigationContext.getElementById(\"Eth1IPV4AddrMaskAwsRow\");if(b==\"1\"){if(g){a.style.display=\"none\";f.style.display=\"none\";if(h){h.style.