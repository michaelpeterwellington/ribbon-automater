ar j=tabNavigationContext.getElementById(\"srvrType-Hidden\");var h=(n.textContent).split(\"\\n\")[2].trim();\nvar g=tabNavigationContext.getElementById(\"Port-Field\");if(\"IP/FQDN\"==h){if(isIPv6Address(a.value)&&isHA()!=\"0\"){d+=\"\\n- Host: The format must be either an IPv4 address or FQDN\"}if(!(isIpAddress(a.value))&&!(isIPv6Address(a.value))&&!(isFQDN(a.value))){d+=\"\\n- Host: The format must be either an IP address or FQDN\"\n}if(isNaN(g.value)||(g.value<1)||(g.value>65535)){d+=\"\\n - Port must be specified and must be a number between 1 and 65535.\"}}else{if(!(isFQDN(b.value))){d+=\"\\n- DomainName: Format is incorrect or blank.\"\n}}if(getContainerType()==\"0\"){var c=tabNavigationContext.getElementById(\"ReuseTimeout-Field\");var m=tabNavigationContext.getElementById(\"transResueTimeout-Field\");if(m.value!=0){if(isNaN(c.value)||c.value<5||c.value>1440){d+=\"\\n- Timeout limit must contain a number between 5 and 1440.\"\n}}}if(getContainerType()==\"0\"){var l=tabNavigationContext.getElementById(\"KaCnt-Field\");var k=tabNavigationContext.getElementById(\"KaIntval-Field\");var e=tabNavigationContext.getElementById(\"TcpKeepAlive-Field\");\nif(e.value!=0){if(isNaN(l.value)||l.value<1||l.value>10){d+=\"\\n- Keep Alive Count must contain a number between 1 and 10.\"}if(isNaN(k.value)||k.value<1||k.value>300){d+=\"\\n- Keep Alive Interval must contain a number between 1 and 300.\"\n}}}var q=tabNavigationContext.getElementById(\"Monitor-Field\");var o=tabNavigationContext.getElementById(\"KeepAliveFrequency-Field\");var r=tabNavigationContext.getElementById(\"RecoverFrequency-Field\");if(q.value!=0){if(isNaN(o.value)||o.value<30||o.value>300){d+=\"\\n- Keep Alive Frequency must contain a number between 30 and 300.\"\n}if(isNaN(r.value)||r.value<5||r.value>300){d+=\"\\n- Recover Frequency must contain a number between 5 and 300.\"}}var p=tabNavigationContext.getElementById(\"LocalUserName-Field\");var f=tabNavigationContext.getElementById(\"PeerUserName-Field\");\nif((isElementVisible(p))&&(!validateUserName(p.value))){d+=\"\\n- Local Username must be valid characters\"}if((isElementVisible(f))&&(!validateUserName(f.value))){d+=\"\\n- Peer Username must be valid characters\"\n}if(d!=\"\"){alert(\"The following errors were found with the SIP Server Configuration.\\n\"+d);document.MM_returnValue=false}else{document.MM_returnValue=true}}function validateRemoteAuthorizationEntry(){var c=\"\";\nvar a=tabNavigationContext.getElementById(\"PwdSetting-Field\");var d=tabNavigationContext.getElementById(\"EncryptedPassword-Field\");var b=tabNavigationContext.getElementById(\"confirmPassword-Field\");if(a==null||(a!=null&&a.value==2)){if(d.value==\"\"){c+=\"\\n- Password can not be empty\"\n}if(b.value==\"\"){c+=\"\\n- Confirm password can not be empty\"}if(d.value!=b.value){c+=\"\\n- Password and Confirm Password must be same.\"}}if(c!=\"\"){alert(\"The following errors were found with the Remote Authorization Configuration.\\n\"+c);\ndocument.MM_returnValue=false}else{document.MM_returnValue=true}}function validateLPAuthorizationEntry(){var d=new Array();var c=new Array();var g=\"\";var h=tabNavigationContext.getElementById(\"PwdSetting-Field\");\nvar e=tabNavigationContext.getElementById(\"AOR1-Field\");var a=tabNavigationContext.getElementById(\"AOR2-Field\");var j=tabNavigationContext.getElementById(\"AorType-Field\");var k=tabNavigationContext.getElementById(\"EncryptedPassword-Field\");\nvar f=tabNavigationContext.getElementById(\"confirmPassword-Field\");var b=tabNavigationContext.getElementById(\"User-Field\");if(j.value==2){if(a.value==\"\"){g+=\"\\n- Address of Record URI is required.\"}else{if((a.value).length>512){g+=\"\\n- Address of Record URI length must me less than 512.\"\n}else{c=a.value.split(\":\");if((c[0]==\"sip\")||(c[0]==\"sips\")||(c[0]==\"tel\")){if(c.length<2||!c[1]){g+=\"\\n- Address of Record URI must have a valid user part after the protocol.\"}else{g+=\"\"}}else{g+=\"\\n- Address of Record URI must 