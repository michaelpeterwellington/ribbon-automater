){l+=\"\\n   - Channel List is mandatory and must not be empty.\\n     At least one Channel must be selected in Channel List.\"\n}}else{d.value=\"1\"}if((p.value!=0)&&(v.value!=0)){var g=tabNavigationContext.getElementById(\"CauseCodes-Field\");if(g.options.length==0){l+=\"\\n- Cause Codes are missing.\"}else{var A=tabNavigationContext.getElementById(\"discCauseCodes-Hidden\");\nA.value=\"\";for(var u=0;u<g.options.length;u++){if(A.value!=\"\"){A.value+=\",\"+g.options[u].value}else{A.value=g.options[u].value}}}}else{var A=tabNavigationContext.getElementById(\"discCauseCodes-Hidden\");\nA.value=\"\"}if(l!=\"\"){alert(\"The following error(s) occurred: \\n\"+l);document.MM_returnValue=false}else{document.MM_returnValue=true}}var actionTimerID=0;function resetAjaxActionTimer(){if(actionTimerID!=0){clearInterval(actionTimerID);\nactionTimerID=0}}function performCCCAjaxAction(d,e,b){var a=XmlHttp.create();var c=\"/cgi/services/ajaxRequestDriver.php?reqType=cccAction&actionType=\"+d;if(b!=null){c+=b}a.open(\"GET\",c,true);a.onreadystatechange=function(){if(a.readyState==4){var f=trim(a.responseText);\nif(f.indexOf(\"ErrorWithDetails\")==0){var g=f.indexOf(\";\");f=f.substring(g+1,f.length);openModalErrorDialog(450,150,f)}else{if(d==52||d==53){ajaxActionStatus(d)}}}};document.MM_returnValue=false;a.send(null)\n}function ajaxActionStatus(a){resetAjaxActionTimer();ajaxActionStatusUpdate(a);if(actionTimerID==0){actionTimerID=setInterval(function(){ajaxActionStatusUpdate(a)},3000)}}function ajaxActionStatusUpdate(c){var a=XmlHttp.create();\nvar b=\"/cgi/services/ajaxActionStatus.php?reqActionType=\"+c;if(c==52||c==53){b+=\"&type=CCC&id=1\"}a.open(\"GET\",b,true);a.onreadystatechange=function(){if(a.readyState==4){var k=trim(a.responseText);var e=new SystemActionStatus();\nif(k.indexOf(\";;\")!=-1){var d=k.indexOf(\";;\");var g=k.substring(0,d);if(g){var h=g.split(\"|\");if(h[0]){e.setStatus(h[0])}if(h[1]){e.setActionType(h[1])}if(h[2]){e.setData1(h[2])}if(h[3]){e.setData2(h[3