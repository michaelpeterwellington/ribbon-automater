            "text": "\n\n\n\n\n\n\n<script type=\"text/javascript\" language=\"JavaScript\" src=\"/javascript/13.0.0-37_rel_views.js\"></script>\n<script type=\"text/javascript\" language=\"JavaScript\" src=\"/javascript/13.0.0-37_rel_toggle_checked.js\"></script>\n<script type=\"text/javascript\" language=\"JavaScript\" src=\"/javascript/13.0.0-37_rel_tableview.js\"></script>\n<script type=\"text/javascript\" language=\"JavaScript\" src=\"/packages/dhtml/js/13.0.0-37_rel_ajax.js\"></script>\n<script type=\"text/javascript\" language=\"javascript\">\ndocument.onkeypress = sonusUIKeyPress;</script>\n<table class=\"DetailsTabTitle\">\n<tr>\n  <td class=\"DetailsTabTitleCol1\"><script>\n    \tfunction hideWarning() {\n      \t\tvar warningMessage = document.getElementById('warningId');\n      \t\twarningMessage.style.display = 'none';\n    \t}\n  \t\t</script>System Overview</td>\n  <td class=\"DetailsTabTitleCol2\"><span style=\"padding-right: 5px;\">February 27, 2026 09:09:09</span></td>  <td class=\"DetailsTabTitleCol2\" style=\"width:48px\"><a href=\"javascript:refreshRightHandContent('System_systemNavTabs','0')\"><span class=\"RefreshImage\" style=\"padding-right: 6px;\" id=\"titleRefresh\" title=\"Refresh this view\"></span></a><span style=\"padding-right: 6px;\"><a target=\"help\" href=\"http%3A%2F%2Fdoc.rbbn.com%2Fdisplay%2FUXDOC130%2FChecking+your+System+Information\" onClick=\"popupHelpWindow('http%3A%2F%2Fdoc.rbbn.com%2Fdisplay%2FUXDOC130%2FChecking+your+System+Information');return false;\" ><span class=\"HelpImage\" title=\"Help\" id=\"titleHelp\"></span></a></span></td>\n</tr>\n</table>\n\n<div class=\"Section\">\n<form autocomplete=\"off\"; style=\"padding-top:0px; margin-top:0px;\" name=\"System_0_popup1\" method=\"post\" action=\"\">\n<div class=\"SectionBody\" id=\"System_0_section_1\"><table style=\"width:95%\" border=\"0\"><tbody>\n<input type=\"hidden\" id = \"openRowId\" name=\"id\" value=\"1\"/>\n<input type=\"hidden\" name=\"rowID\" value=\"1\"/>