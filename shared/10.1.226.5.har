            "mimeType": "text/html",
            "text": "\n\n\n\n\n\n\n<div id=\"Tasks_dhtmlgoodies_xpPane\" class=\"AccordionPane\">\n\t<div class=\"dhtmlgoodies_panel\" id=\"shortcutGroup6\">\n\t\t<div style=\"padding-top:10px; padding-bottom:10px;margin-left:-20px;\">\n\t<div id=\"swupgrade\"><table><tr>\n                                <td><span class=\"BulletPoint\"/></td>\n                                <td><a href=\"javascript:showRightHandContent('/cgi/phpUI/config.php?cfg=/views/system/codeUploadTask.xml&type=Partition&popup=false','TasksNav','swupgrade','|Partition|')\"><b>Software Upgrade</b></a>\n                                </td></tr></table></div>\n\t<div id=\"BackupRestore\"><table><tr>\n                                <td><span class=\"BulletPoint\"/></td>\n                                <td><a href=\"javascript:showRightHandContent('/cgi/phpUI/config.php?cfg=/views/system/backupRestore.xml&type=Partition&popup=false','TasksNav','BackupRestore',null)\"><b>Backup/Restore Config</b></a>\n                                </td></tr></table></div>\n\t<div id=\"rebootux\"><table><tr>\n                                <td><span class=\"BulletPoint\"/></td>\n                                <td><a href=\"javascript:showRightHandContent('/cgi/system/reboot.php','TasksNav','rebootux',null)\"><b>Reboot SBC Edge</b></a>\n                                </td></tr></table></div>\n\t<div id=\"factorydefault\"><table><tr>\n                                <td><span class=\"BulletPoint\"/></td>\n                                <td><a href=\"javascript:showRightHandContent('/cgi/phpUI/config.php?cfg=/views/system/FactoryDefault.xml&popup=false','TasksNav','factorydefault',null)\"><b>SBC Edge Factory Default</b></a>\n                                </td></tr></table></div>\n\t<div id=\"partialconfigimport\"><table><tr>\n                                <td><span class=\"BulletPoint\"/></td>\n                                <td><a href=\"javascript:showRightHandContent('/cgi/phpUI/config.php?cfg=/views/sy