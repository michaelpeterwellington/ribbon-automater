          "content": {
            "size": 10142,
            "mimeType": "text/javascript",
            "text": "/*\n\n This is one of the free scripts from www.dhtmlgoodies.com\n You are free to use this script as long as this copyright message is kept intact\n\n (c) Alf Magne Kalleland, http://www.dhtmlgoodies.com - 2005\n\n */\n\n/**\n *\n *                         N.E.T. CONFIDENTIAL\n *\n *  This listing of source code is proprietary and confidential to\n *  Network Equipment Technologies, Inc., d.b.a. net.com. It may not\n *  be copied or made available in any form (electronic or hard copy)\n *  to any person not authorized by Network Equipment Technologies,\n *  Inc. Unpublished-Rights reserved under all copyright laws.\n *\n *                Copyright (C) 2009\n *                Network Equipment Technologies, Inc.\n *                6900 Paseo Padre Parkway\n *                Fremont, CA  94555-3660, U.S.A.\n */\n\n/**\n * Description of dhtml_tree.js\n *\n * Date: Oct 22, 2010\n * Time: 11:11:17 AM\n * @author prakashc\n */\n\nfunction expandTree() {\n    if (uxTreeObject) {\n        uxTreeObject.expandAll();\n    } else {\n        alert('Failed to expand tree. Internal presentation error.\\nPlease refresh and try again.');\n    }\n}\nfunction collapseTree() {\n    if (uxTreeObject) {\n        uxTreeObject.collapseAll();\n    } else {\n        alert('Failed to collapse tree. Internal presentation error.\\nPlease refresh and try again.');\n    }\n}\n\nfunction refreshTreeContent(doInitialNavigation) {\n    if ((doInitialNavigation == null) || (!(doInitialNavigation))) {\n        doInitialNavigation = false;\n    }\n    else {\n        doInitialNavigation = true;\n    }\n    \n    for (var tabIndex in tabViewPropertiesArray) {\n        var tabProps = tabViewPropertiesArray[tabIndex];\n        var paneList = tabProps.getPaneList();\n        for (var paneIndex in paneList) {\n            var paneProps = paneList[paneIndex];\n            var contentURL = paneProps.getContentURL();\n            if ((contentURL != null) && (contentURL.indexOf('/cgi/tree/tree.php') >= 0)) {\n                var paneID = tabProps.getInnerPaneID(paneProps);\n                var newContentURL = contentURL.substring(0, (contentURL.indexOf('?') + 1));\n                var argList = (contentURL.indexOf('?') == -1) ? '' : contentURL.substring(contentURL.indexOf('?') + 1);\n                var argListArray = argList.split('&');\n                var foundDoInitial = false;\n                for (var argListIndex = 0; argListIndex < argListArray.length; argListIndex++) {\n                    var nameValueArr = argListArray[argListIndex].split('=');\n                    if (nameValueArr.length == 2) {\n                        if (nameValueArr[0] == 'doInitialNavigation') {\n                            foundDoInitial = true;\n                            nameValueArr[1] = (doInitialNavigation) ? \"true\" : \"false\";\n                        }\n                    }\n                    argListArray[argListIndex] = nameValueArr.join('=');\n                }\n                if ((!(foundDoInitial)) && (doInitialNavigation)) {\n                    argListArray[argListIndex] = 'doInitialNavigation=true';\n                }\n                argList = argListArray.join('&');\n                newContentURL += argList;\n                $uxDocQuery(\"#\" + paneID).load(newContentURL, function(data) {\n                    //alert(data);\n                });\n            }\n        }\n    }\n}\n\nfunction cancelTreeSearch() {\n    var f = document.getElementById('filterField');\n    f.value = f.defaultValue;\n    f.style.color='gray';\n    var scRightCtrlEle = document.getElementById('scRight');\n    if (scRightCtrlEle) {\n        if (scRightCtrlEle.className != 'SC_Right') {\n            scRightCtrlEle.className='SC_Right';\n            scRightCtrlEle.title='Start typing to search...';\n        }\n    }\n}\nfunction clearTreeSCText(f) {\n    if (f.defaultValue == f.value) {\n        f.value = '';\n        f.style.color='black';\n    }\n    else if (f.value == '') {\n        f.value = f.defaultValue;\n        f.style.color='silver';\n    }\n}\nfunction updateTreeSCStyle(f) {\n    var scRightCtrlEle = document.getElementById('scRight');\n    if (scRightCtrlEle) {\n        if (f.value == '' || f.value == null) {\n            if (scRightCtrlEle.className != 'SC_Right') {\n                scRightCtrlEle.className='SC_Right';\n                scRightCtrlEle.title='Start typing to search...';\n            }\n        } else {\n            if (scRightCtrlEle.className != 'SC_Right_Cross') {\n                scRightCtrlEle.className='SC_Right_Cross';\n                scRightCtrlEle.title='Click to cancel the search.';\n            }\n        }\n    }\n}\nfunction treeNodeStyleUpdate(eName, el) {\n    if (uxTreeObject) {\n        uxTreeObject.updateNodeStyle(eName, el);\n    } else {\n        alert('Failed to handle tree node selection. Internal presentation error.\\nPlease refresh and try again.');\n    }\n}\n\nDHTMLSuite.tree = function(propArray) {\n    var plusNode, minusNode;\n    var nameOfCookie;\n    var activeNode;\n    var preActiveNode;\n    var initExpandedNodes;\n    if (propArray) this.setInitProperties(propArray);\n}\nDHTMLSuite.tree.prototype =\n{\n    expandAll : function () {\n        var treeObj = document.getElementById('dhtmlgoodies_tree');\n\tvar images = treeObj.getElementsByTagName('SPAN');\n        //alert('Count: '+images.length);\n        for (var no = 0; no < images.length; no++) {\n            if (images[no].className == this.plusNode) {\n                this.expandNode(false, images[no]);\n            }\n        }\n    },\n    collapseAll : function () {\n        var treeObj = document.getElementById('dhtmlgoodies_tree');\n\tvar images = treeObj.getElementsByTagName('SPAN');\n        for (var no = 0; no < images.length; no++) {\n            if (images[no].className == this.minusNode) {\n                this.expandNode(false, images[no]);\n            }\n        }\n    },\n    expandNode : function (e, inputNode) {\n        if (this.initExpandedNodes.length == 0) this.initExpandedNodes = \",\";\n        if (!inputNode) inputNode = this;\n        inputNode = inputNode.parentNode.getElementsByTagName('span')[0]; // Make sure we have the first child span (the chevron)\n\n        var inputId = inputNode.id.replace(/[^\\d]/g, '');\n\n        var parentUl = inputNode.parentNode;\n\t    var subUl = parentUl.getElementsByTagName('UL');\n        if (subUl.length == 0) return;\n\n        // folder/leaf image\n        var folderImgNode = inputNode.parentNode.getElementsByTagName('SPAN')[1]; // TODO: change back to index 1 when plusminus is changed from img to span\n        \n        if (subUl[0].style.display == '' || subUl[0].style.display == 'none') {\n            subUl[0].style.display = 'block';\n            inputNode.className = this.minusNode;\n            this.initExpandedNodes = this.initExpandedNodes.replace(',' + inputId + ',', ',');\n            this.initExpandedNodes = this.initExpandedNodes + inputId + ',';\n            if (folderImgNode) {\n                folderImgNode.className = 'TreeOpenFolder';\n            }\n        } \n        else {\n            subUl[0].style.display = '';\n            inputNode.className = this.plusNode;\n            this.initExpandedNodes = this.initExpandedNodes.replace(',' + inputId + ',', ',');\n            if (folderImgNode) {\n                folderImgNode.className = 'TreeClosedFolder';\n            }\n        }\n        cookie(this.nameOfCookie, this.initExpandedNodes, {duration: 30, secure: true, samesite: \"Strict\"});\n    },\n    initTree : function () {\n        // Assigning mouse events\n        var parentNode = document.getElementById('dhtmlgoodies_tree');\n\t\tvar lis = parentNode.getElementsByTagName('LI');\n        for (var no = 0; no < lis.length; no++) {\n\t        var subNodes = lis[no].getElementsByTagName('UL')            \n            if (subNodes.length > 0) {\n                lis[no].childNodes[0].style.visibility = 'visible';\n            } \n            else {\n                lis[no].childNodes[0].style.visibility = 'hidden';\n            }\n        }\n\n        $uxDocQuery(\"#dhtmlgoodies_tree SPAN\").bind({\n            click: function() {\n                uxTreeObject.expandNode(false, this);\n            }\n        });\n\n        var cursor = 'pointer';\n        if (document.all) cursor = 'hand';\n        $uxDocQuery(\"#dhtmlgoodies_tree A\").bind({\n            dblclick: function() {\n                uxTreeObject.expandNode(false, this);                \n            }\n        });\n\n        if (this.initExpandedNodes && this.initExpandedNodes != '') {\n            var initExpandedArray = this.initExpandedNodes.split(',');\n            for (var no = 0; no < initExpandedArray.length; no++) {\n                if(document.getElementById('plusMinus' + initExpandedArray[no])) {\n                    var obj = document.getElementById('plusMinus' + initExpandedArray[no]);\n                    this.expandNode(false,obj);\n                }\n            }\n        }\n        this.attachHandlers(\"dhtmlgoodies_tree\");\n    },\n    attachHandlers : function (inputNodeID) {\n        // attach event handlers to tree_links under tree\n        $uxDocQuery(\"#\"+inputNodeID +\" > ul:first\").find('.tree_link').bind({\n            click: function() {\n                treeNodeStyleUpdate('mouseClick', this);\n            },\n            dblclick: function() {\n                treeNodeStyleUpdate('mouseDblClick', this);\n            },\n            mouseover: function() {\n                treeNodeStyleUpdate('mouseOver', this);\n            },\n            mouseout: function() {\n                treeNodeStyleUpdate('mouseOut', this);\n            }\n        });\n    },\n    updateNodeStyle : function (eventName, e) {\n        if (eventName == 'mouseClick' || eventName == 'mouseDblClick') {\n            if (this.preActiveNode && (this.preActiveNode != e)) {\n                