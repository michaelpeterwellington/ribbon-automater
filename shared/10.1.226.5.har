            "text": "\n\n\n\n\n\n<script type=\"text/javascript\" language=\"JavaScript\">function updateNavCtxAndCallUnload() {tabViewUnloadUpdateNavContext();}function tabViewContainerOnload() {}\nfunction System_0_viewOnLoad() {eval('tabViewContainerOnload()');}\nfunction System_0_viewUnLoad() {eval('updateNavCtxAndCallUnload()');}\nfunction System_1_viewOnLoad() {eval('tabViewContainerOnload()');}\nfunction System_1_viewUnLoad() {eval('updateNavCtxAndCallUnload()');}\nfunction System_2_viewOnLoad() {eval('tabViewContainerOnload()');}\nfunction System_2_viewUnLoad() {eval('updateNavCtxAndCallUnload()');}</script><div><div id=\"System_systemNavTabs\"><ul>\n\t<li><a title=\"System Overview\" href=\"/cgi/phpUI/callDetailsEngine.php?cfg=/views/system/systemOverview.xml&type=System&id=1&titleType=detailsTab&popup=false&navigationContext=System_0&tabContainer=System_systemNavTabs&tabId=0&renderOnLoadUnload=no\">Overview</a></li>\n\t<li><a title=\"System Statistics\" href=\"/cgi/phpUI/callDetailsEngine.php?cfg=/views/system/sysCallStats.xml&type=SystemCallStats&id=1&hasTitle=no&popup=false&navigationContext=System_1&tabContainer=System_systemNavTabs&tabId=1&renderOnLoadUnload=no\">Statistics</a></li>\n\t<li><a title=\"System About SBC Edge\" href=\"/cgi/phpUI/callDetailsEngine.php?cfg=/views/system/about.xml&type=System&id=1&hasTitle=no&popup=false&navigationContext=System_2&tabContainer=System_systemNavTabs&tabId=2&renderOnLoadUnload=no\">About SBC Edge</a></li>\n\n</ul></div>\n\n            <script type=\"text/javascript\" language=\"JavaScript\">\n\tvar tabStates = new Array(false, false, false);\n\tvar tab2Guide = new Array();\n\tvar tabLinks = new Array('/cgi/phpUI/callDetailsEngine.php?cfg=/views/system/systemOverview.xml&type=System&id=1&titleType=detailsTab&popup=false&navigationContext=System_0&tabContainer=System_systemNavTabs&tabId=0&renderOnLoadUnload=no', '/cgi/phpUI/callDetailsEngine.php?cfg=/views/system/sysCallStats.xml&type=SystemCallStats&id=1&hasTitle=no&popup=false&navigationContext=System_1&tabContainer=System_systemNavTabs&tabId=1&renderOnLoadUnload=no', '/cgi/phpUI/callDetailsEngine.php?cfg=/views/system/about.xml&type=System&id=1&hasTitle=no&popup=false&navigationContext=System_2&tabContainer=System_systemNavTabs&tabId=2&renderOnLoadUnload=no');\n var tabName = tabNavigationContext.getContextByLevel(0);\nif (tabViewPropertiesArray[tabName]) { \nvar tabViewProps = tabViewPropertiesArray[tabName]; \ntabViewProps.setGuidance(tab2Guide); } \nvar loadedTabIndex = 0;\n$uxDocQuery(function() {\n                    $uxDocQuery('#System_systemNavTabs').tabs({\n                        fx: {opacity: 'toggle', duration:'fast'},active: 0,cache: true,load: function (event, ui) {\n                            // remove  the loading message\n                            //alert('(tabswitchJS null) load: entering: '+ui.tab.index()+' state:'+tabStates[ui.tab.index()]);\n                            $uxDocQuery('#System_systemNavTabs').tabs(\"widget\").find(\".tab-loading\").remove();\n                            $uxDocQuery(ui.panel).find(\".tab-loading\").remove();\n                            tabStates[ui.tab.index()] = true;\n                            tabNavigationContext.tabNavigationAction(ui.tab.index(), 1);\n                            updateNextStepForTab(ui);\n                            updateTabDivAttribs(event, ui);\n                            loadedTabIndex = ui.tab.index();\n                            //alert('load: done: '+ui.index+' state:'+tabStates[ui.tab.index()]);\n                        },\n                        activate: function (event, ui) {\n                            //alert('(tabswitchJS null) activate: state: '+tabStates[ui.newTab.index()] + ' index:'+ui.newTab.index());\n                                updateNextStepForTab(ui);\n                            tabNavigationContext.tabNavigationAction(ui.newTab.index(), 1);\n                        },beforeLoad: function(event, ui) {\n                            var panel = $uxDocQuery(ui.panel);\n                            //console.log('in beforeLoad ' + ui.tab.index() + ', ui panel : ' + panel.id + ', empty: ' + panel.is(\":empty\"));\n                            if (ui.tab.index() == 0 && panel.is(\":empty\")) {\n                                $uxDocQuery('#System_systemNavTabs').tabs(\"widget\").append(\"<div class='tab-loading' style='text-align:center; padding:10px'><span class='LoadingContentImage'></span><div style='text-align:center;'> Loading content-please wait...</div></div>\");                               \n                            }\n                },\n                    beforeActivate: function (event, ui) {\n                            //alert('select: entering: '+ui.newTab.index()+' state:'+tabStates[ui.newTab.index()]);\n                            //if (!tabStates[ui.index]) {\n                                var panel = $uxDocQuery(ui.newPanel);\n                                if (panel.is(\":empty\")) {\n                                    panel.append(\"<div class='tab-loading' style='text-align:center; padding:10px'><span class='LoadingContentImage'></span><div style='text-align:center;'> Loading content-please wait...</div></div>\");\n                                }\n                            //}\n                        },\n                    ajaxOptions: {\n                            error: function(xhr, status, index, anchor) {\n                                //alert('error:'+index+' state:'+tabStates[ui.index]);\n                                $uxDocQuery(anchor.hash).html(\"Failed to load tab content. Refreshing the view might fix the issue.\");\n                                //tabStates[index] = true;\n                                /*for (var i=0; i<tabStates.length;i++) {\n                                    loadNextTab(i);\n                                }*/\n                            },\n                            success: function(data, textStatus) {\n                                //alert('success:'+loadedTabIndex+' state:'+tabStates[loadedTabIndex]);\n                                /*tabStates[loadedTabIndex] = true;\n                                if (indexesToLoad.length == 0) {\n                                    $uxDocQuery('#System_systemNavTabs').tabs('option', 'disabled', []);\n                                    return;\n                                }\n                                var index = indexesToLoad.shift();\n                                if (index == loadedTabIndex) {\n                                    index = indexesToLoad.shift();\n                                }\n                                if (tabStates[index]) return;\n                                loadNextTab(index);\n                                */\n                            }\n                        }\n                    });\n                });\n                /*function loadNextTab(tabIndex) {\n                    //alert('loadNextTab: is tab loaded for index: '+tabIndex+'=>'+tabStates[tabIndex]);\n                    $uxDocQuery('#System_systemNavTabs').tabs('load', tabIndex);\n                }*/\n                function updateTabDivAttribs(event, ui) {\n\t\t    var tabEle = $uxDocQuery('#'+ 'System_systemNavTabs').find('.ui-tabs-panel')[ui.tab.index()];\n                    tabEle.setAttribute('contentURL', tabLinks[ui.tab.index()]);\n                    tabEle.setAttribute('__tabContainerId', 'System_systemNavTabs');\n                    tabEle.setAttribute('__tabId', ui.tab.index());\n\t\t    var tabId = tabEle.getAttribute('id');\n\n                    var moTypes = $uxDocQuery('#'+tabId+' input[name=\"tableMOTypes\"]');\n                    if (moTypes.length == 0) {\n                        moTypes = $uxDocQuery('#'+tabId+' input[name=\"type\"]');\n                    }\n                    if (moTypes.length > 0) {\n                        if (moTypes.val() != '') {\n                        