=\"\";c.style.display=\"\";if(b==\"0\"){d.style.display=\"none\"}else{d.style.display=\"\"}}}function setFieldAndHighlight(c,b){var a=tabNavigationContext.getElementById(c+\"-Field\");\nif(null==a){return}a.value=b;highlightChangedFieldWidget(c)}function setIfIpAddrAssignMethod(b){var e=initialSetupIsPublicCloud();if(!(e)){var c=tabNavigationContext.getElementById(\"adminIpAddrAssignMethod-Hidden\");\nc.value=b}if(\"1\"==b){setRowVisibility(\"domainNameRow\",\"none\");setRowVisibility(\"DefaultIPRouteFGRow\",\"none\");if(!isPlatformVSBCE()){setRowVisibility(\"Ethernet1HR\",\"none\");setRowVisibility(\"ipV4Address\",\"none\");\nsetRowVisibility(\"ipV4Netmask\",\"none\")}else{setRowVisibility(\"AdminIPAddressFGRow\",\"none\");setRowVisibility(\"adminIpV4Address\",\"none\");setRowVisibility(\"adminIpV4Netmask\",\"none\")}setRowVisibility(\"DNSFGRow\",\"none\");\nsetRowVisibility(\"AdditionalStaticRouteFGRow\",\"none\");var d=tabNavigationContext.getElementById(\"hostName-Field\");if(d.value==\"\"){var a=tabNavigationContext.getElementById(\"defaultHostName-Hidden\");d.value=a.value\n}}else{if(isPlatformVSBCE()){if(e){setRowVisibility(\"AdminIPAddressFGRow\",\"none\");setRowVisibility(\"adminIpV4Address\",\"none\");setRowVisibility(\"adminIpV4Netmask\",\"none\")}else{setRowVisibility(\"AdminIPAddressFGRow\",\"\");\nsetRowVisibility(\"adminIpV4Address\",\"\");setRowVisibility(\"adminIpV4Netmask\",\"\")}}setRowVisibility(\"domainNameRow\",\"\");setRowVisibility(\"DefaultIPRouteFGRow\",\"\");setRowVisibility(\"Ethernet1HR\",\"\");if(!isPlatformVSBCE()){setRowVisibility(\"ipV4Address\",\"\");\nsetRowVisibility(\"ipV4Netmask\",\"\")}setRowVisibility(\"DNSFGRow\",\"\");setRowVisibility(\"AdditionalStaticRouteFGRow\",\"\");setRowVisibility(\"IPAddressFGRow\",\"\")}if(getContainerType()!=\"1\"){initSetupSetConfigBannerDisplay(b)\n}}function initSetupSetConfigBannerDisplay(c){if(isPlatformVSBCE()){var a=tabNavigationContext.getElementById(\"defaultMapping-Hidden\");var f=tabNavi