lue=a.getAttribute(\"origvalue\");\nupdateMstpStateField(a.value);alert('Default Untagged VLAN must be set to \"'+f.options[b].text+'\"  before Failover Redundancy is set.')}}}updateMstpStateField(a.value)}function updateDhcpStateField(b){var a=tabNavigationContext.getElementById(\"ConfigureSplitDNSRow\");\nif(b!=2){a.style.display=\"none\"}else{a.style.display=\"\"}}function dhcpSuppliedParametersUpdated(){var a=tabNavigationContext.getElementById(\"DHCPSuppliedParamUsage-Field\");updateDhcpStateField(a.value)\n}function initEthernetPort(){var e=tabNavigationContext.getElementById(\"ifNetworkingMode-Field\");var g=tabNavigationContext.getElementById(\"ConfigIEState-Field\");var f=tabNavigationContext.getElementById(\"ifName-Hidden\");\nvar d=tabNavigationContext.getElementById(\"ifDefaultVid-Field\");var c=tabNavigationContext.getElementById(\"defaultVid-Hidden\");var b=tabNavigationContext.getElementById(\"ifRedundancy-Field\");if(d!=null){d.value=c.value.replace(\".\",\":\")\n}var a=getUXModel();if(e){networkingMode=e.value}else{networkingMode=0}if(a==\"UX2000\"){setBridgeIDField(networkingMode)}if(b){updateMstpStateField(b.value)}setAdminStateOptions(f.value,g);setEthernetOptions(f.value,a);\nframeTypeUpdated();ifSpeedUpdated();if((f.value.indexOf(\"lan\")==0)||(f.value.indexOf(\"Ethernet\")==0)){setRedundancyOptions(f.value)}}function setRedundancyOptions(l){var e=tabNavigationContext.getElementById(\"ifRedundancy-Field\");\nvar g=tabNavigationContext.getElementById(\"rt_redundancyRole-Span\");var k=tabNavigationContext.getElementById(\"RedundantPort-id\");var b=tabNavigationContext.getElementById(\"RedundantPortL-id\");var p=tabNavigationContext.getElementById(\"RedundancyRole-id\");\nvar n=tabNavigationContext.getElementById(\"RedundancyState-id\");var o=tabNavigationContext.getElementById(\"aclInInstance-id\");var d=tabNavigationContext.getElementById(\"aclForwardInstance-id\");var h=tabNavigationContext.getElementById(\"aclInInstanceL-id\");\nvar q=tabNavigationContext.getElementById(\"aclForwardInstanceL-id\");var a=tabNavigationContext.getElementById(\"ifFrameTypeIdRow\");var j=tabNavigationContext.getElementById(\"ifFrameTypeLabel-id\");var m=tabNavigationContext.getElementById(\"ifDefaultVid\");\nvar c=tabNavigationContext.getElementById(\"hybridVlanIdRowId\");var f=getUXModel();if(e.value==\"2\"){p.style.display=\"\";n.style.display=\"\";a.style.display=\"none\";j.style.display=\"\";m.style.display=\"none\";\nc.style.display=\"none\";if(g.childNodes[0].innerHTML==\"Primary\"){k.style.display=\"\";b.style.display=\"none\";if(f==\"UX2000\"){o.style.display=\"\";d.style.display=\"\";h.style.display=\"none\";q.style.display=\"none\"\n}}else{k.style.display=\"none\";b.style.display=\"\";if(f==\"UX2000\"){o.style.display=\"none\";d.style.display=\"none\";h.style.display=\"\";q.style.display=\"\"}}}else{a.style.display=\"\";j.style.display=\"none\";p.style.display=\"none\";\nn.style.display=\"none\";k.style.display=\"none\";b.style.display=\"none\";frameTypeUpdated();if(f==\"UX2000\"){o.style.display=\"\";d.style.display=\"\";h.style.display=\"none\";q.style.display=\"none\"}}}function setEthernetOptions(d,b){var c=tabNavigationContext.getElementById(\"ifConfiguredSpeedRow\");\nvar a=tabNavigationContext.getElementById(\"ifConfiguredDuplexityRow\");if(b==\"UX2000\"){if(d==\"mgmt1\"){c.style.display=\"none\";a.style.display=\"none\"}else{c.style.display=\"\";a.style.display=\"\"}}if(b==\"UX1000\"&&d!=\"ASM\"){if(d==\"mgmt1\"){c.style.display=\"none\";\na.style.display=\"none\"}else{c.style.display=\"\";a.style.display=\"\"}}}function frameTypeUpdated(){var a=tabNavigationContext.getElementById(\"ifFrameType-Field\");if(a!=null){setDefaultVlanIdField(a.value);\nsetHybridVlanRowField(a.value)}}function isASMPort(a){return(a==\"sba1\"||a==\"asm1\"||a==\"sba2\"||a==\"asm2\"||a==\"ASM\"||a==\"ASM Link 1\"||a==\"ASM Link 2\")}function ethernetPortSubmit(){var h=tabNavigationContext.getElementById(\"ifName-Hidden\");\ndocument.MM_returnValue=true;var z=tabNavigationContext.getElementById(\"ifBridgeGroupId-Hidden\");z.value=1;var f=tabNavigationContext.getElementById(\"ifIPv4AddressPrimary-Field\");var n=tabNavigationContext.getElementById(\"ifIPv4AddressPrimaryMask-Field\");\nif((f)&&(n)){if((f.value==\"0.0.0.0\")){if(!confirm(\"If the address is set to 0.0.0.0\\nit will de-configure the IP address.\\n\\nAre you sure you want to do this?\")){document.MM_returnValue=false;return false\n}}}var g=tabNavigationContext.getElementById(\"ifFrameType-Field\");var A=tabNavigationContext.getElementById(\"ifHybridVlanString-Hidden\");A.value=\"\";var o=tabNavigationContext.getElementById(\"ifHybridVlan-Field\");\nif(null!=g){if(1==g.value){o.value=null}else{if(o!=null){for(var t=0;t<o.options.length;t++){if(A.value!=\"\"){A.value+=\",\"+o.options[t].value}else{A.value=o.options[t].value}}}}}var w=tabNavigationContext.getElementById(\"aclInInstanceID-Field\");\nvar c=tabNavigationContext.getElementById(\"aclForwardInstanceID-Field\");var s=\"\";if(null!=w&&null!=c){if(w.value!=\"0\"&&c.value!=\"0\"){if(w.value==c.value){s=\"Warning: Applying same ACL's on both directions  \\n\\nAre you sure this is what you want to do?\"\n}if(s!=\"\"){if(!confirm(s)){document.MM_returnValue=false}}}}var r=tabNavigationContext.getElementById(\"gigabitTimingMode-Field\");var j=\"\";if(r){var u=tabNavigationContext.getElementById(\"gigabitTimingMode-Hidden\");\nif((u.value==0)&&(r.value!=0)){j=\"Warning: Unless required for switch interoperability, \\nit is recommended that the Gigabit Timing Mode be left as 'Auto'. \\n\\nAre you sure you want to change this value?\";\nif(j!=\"\"){if(!confirm(j)){document.MM_returnValue=false}}}}if(h&&isASMPort(h.value)&&isUX2000()){var k=\"\";var p=-1;var q=tabNavigationContext.getElementById(\"ifNetworkingMode-Field\");if(q){p=q.getAttribute(\"origvalue\");\nif(p!=q.value){k=\"Warning: Modifying 'Networking Mode' can result in loss of connectivity between the ASM and the SBC. \\n\\nAre you sure this is what you want to do?\"}}var m=tabNavigationContext.getElementById(\"ifBridgeGroupId-Field\");\nif(m&&k==\"\"){p=m.getAttribute(\"origvalue\");if(p!=m.value){k=\"Warning: Modifying 'Bridge Group ID' can result in loss of connectivity between the ASM and the SBC. \\n\\nAre you sure this is what you want to do?\"\n}}if(k!=\"\"){if(!confirm(k)){document.MM_returnValue=false}}}var y=\"\";var v=\"\";var a=tabNavigationContext.getElementById(\"ifConfiguredDuplexity-Field\");var l=tabNavigationContext.getElementById(\"ifConfiguredSpeed-Field\");\nif((l)&&(a)){if((l.value!=3)||(a.value!=2)){if(l.value!=3&&(a.value!=2)){v+=\"these configured Speed and configured Duplexity values?\";y+=\"configured Speed and the configured Duplexity values are not Auto,\"\n}else{var e=(l.value!=3)?\"Speed\":\"Duplexity\";v+=\"this configured \"+e+\" value?\";y+=\"configured \"+e+\" value is not Auto,\"}}}var x=\"\";if(y!=\"\"){x+=\"If the \"+y+\" and the configuration does not match the attached device, the interface will become unreachable.\";\nx+=\"\\nIf this interface is used for management, then the node may become unreachable.\";x+=\"\\nAre you sure you want to use \"+v}if(x!=\"\"){if(!confirm(x)){document.MM_returnValue=false}}var b=false;$uxDocQuery.each($uxDocQuery('[class^=\"Edited\"]'),function(){b=true\n});var d=\"\";if(b==true&&document.MM_returnValue==true){d+=\"\\nApplying Configuration can cause brief disruption in IP Connectivity\";d+=\"\\nAre you sure you want to Continue?\"}else{if(b==false){d+=\"Configuration has not been changed.\";\nd+=\"\\nApplying Configuration can cause brief disruption in IP Connectivity\";d+=\"\\nAre you sure you want to Continue?\"}}if(d!=\"\"){if(!confirm(d)){document.MM_returnValue=false}}}function configureIfIpAddressingMode(){var a=tabNavigationContext.getElementById(\"ifNetworkingMode-Field\");\nif(!a){a=tabNavigationContext.getElementById(\"ifNetworkingMode-Hidden\")}var b=tabNavigationContext.getElementById(\"ipAddressingMode-Field\");setIPAddressFields(a.value)}function configureMediaNextHopIPVisibility(){var c=tabNavigationContext.getElementById(\"ifName-Hidden\");\nvar b=document.getElementById(\"__m_Edge8KChassis-Hidden\");if(c.value!=\"mgt0\"){if(!(c.value==\"Ethernet 2\"&&b.value==1)){var a=tabNavigationContext.getElementById(\"ifIPv4AddressPrimary-Field\");if(!isVSBCE()||a.value.indexOf(\"169.254\")!=0){tabNavigationContext.getElementById(\"ifIPv4AddressNextHop\").style.display=\"\"\n}else{tabNavigationContext.getElementById(\"ifIPv4AddressNextHop\").style.display=\"none\"}}}}function configureIfIpAddrAssignMethod(){var a=tabNavigationContext.getElementById(\"ifNetworkingMode-Field\");if(!a){a=tabNavigationContext.getElementById(\"ifNetworkingMode-Hidden\")\n}setIPAddressFields(a.value)}function configureSecondaryV4Updated(){var a=getUXModel();if(a!=\"vSBCEnterprise\"){var e=tabNavigationContext.getElementById(\"redundantPort-Hidden\").value;var b=tabNavigationContext.getElementById(\"ifNetworkingMode-Field\");\nif(!(b)){b=tabNavigationContext.getElementById(\"ifNetworkingMode-Hidden\")}var d=tabNavigationContext.getElementById(\"ipAddressingMode-Field\");var c=tabNavigationContext.getElementById(\"ifIPv4ConfigSecondaryEnabled-Field\");\nsetIPv4SecondaryFields(b.value,d.value,c.value,uxModell,e.value)}}function ipv6AutoEnabledUpdated(){var a=tabNavigationContext.getElementById(\"ifNetworkingMode-Field\");var c=tabNavigationContext.getElementById(\"ipAddressingMode-Field\");\nvar b=tabNavigationContext.getElementById(\"ifIPv6AutoConfigurationEnabled-Field\");setIPv6AutoFields(a.value,c.value,b.value)}function setAdminStateOptions(a,b){if(b!=null){if(((a==\"mgmt1\")||(a==\"eth0\"))&&(b.value==\"1\")){b.options[1]=null\n}}}function setIPAddressFields(g){var a=getUXModel();var d=tabNavigationContext.getElementById(\"ipAddressingMode-Field\");var e=tabNavigationContext.getElementById(\"isRedundantRow-Banner\");var c=tabNavigationContext.getElementById(\"isRedundantRow-BannerText\");\nvar f=tabNavigationContext.getElementById(\"redundantPort-Hidden\");var b;var a=getUXModel();if(f.value!=\"0\"){b=\"Paired with Port Ethernet \"+f.value+\". View Ethernet \"+f.value+\" IP interface for configuration.\";\nc.innerHTML=b;e.style.display=\"\";addressingModeRow.style.display=\"none\"}else{c.innerHTML=null;e.style.display=\"none\"}setIPv4AddressFields(g,d.value,a,f.value);setIPv6AddressFields(g,d.value,a,f.value)}function setIPv4AddressFields(p,c,f,m){var g=tabNavigationContext.getElementById(\"ifIPv4AddressPrimaryRow\");\nvar o=tabNavigationContext.getElementById(\"ifIPv4AddressPrimaryMaskRow\");var j=tabNavigationContext.getElementById(\"ifIPv4ConfigSecondaryEnabledRow\");var k=tabNavigationContext.getElementById(\"rt_ifIPv4AddressRow\");\nvar l=tabNavigationContext.getElementById(\"rt_ifIPv4NetmaskRow\");var d=tabNavigationContext.getElementById(\"ifIPv4IpAddrAssignMethodRow\");var q=tabNavigationContext.getElementById(\"ifIPv4FGRow\");var e=tabNavigationContext.getElementById(\"ifIpAddrAssignMethod-Field\");\nvar a=tabNavigationContext.getElementById(\"ifIPv4ConfigSecondaryEnabled-Field\");var b=tabNavigationContext.getElementById(\"ifName-Hidden\");var h=tabNavigationContext.getElementById(\"DHCPSuppliedParamUsageRow\");\nvar n=tabNavigationContext.getElementById(\"ConfigureSplitDNSRow\");if(c==1||m!=0){g.style.display=\"none\";o.style.display=\"none\";if(f!=\"vSBCEnterprise\"){j.style.display=\"none\"}k.style.display=\"none\";l.style.display=\"none\";\nq.style.display=\"none\";if(d){d.style.display=\"none\"}h.style.display=\"none\";n.style.display=\"none\"}else{q.style.display=\"\";if(d){d.style.display=\"\"}if(f==\"vSBCEnterprise\"){if(b.value!=\"mgmt1\"&&b.value!=\"High Availability\"){if(null!=e&&e.value==1){g.style.display=\"none\";\no.style.display=\"none\";k.style.display=\"\";l.style.display=\"\";h.style.display=\"\";dhcpSuppliedParametersUpdated()}else{g.style.display=\"\";o.style.display=\"\";k.style.display=\"none\";l.style.display=\"none\";\nh.style.display=\"none\";n.style.display=\"none\"}}}if(f!=\"vSBCEnterprise\"){if(null!=e&&e.value==1){g.style.display=\"none\";o.style.display=\"none\";j.style.display=\"none\";k.style.display=\"\";l.style.display=\"\";\nh.style.display=\"\";dhcpSuppliedParametersUpdated()}else{g.style.display=\"\";o.style.display=\"\";j.style.display=\"\";k.style.display=\"none\";l.style.display=\"none\";h.style.display=\"none\";n.style.display=\"none\"\n}}}if(f!=\"vSBCEnterprise\"){setIPv4SecondaryFields(p,c,a.value,f,m)}}function setIPv4SecondaryFields(j,d,b,f,g){var h=tabNavigationContext.getElementById(\"ifIPv4AddressSecondaryRow\");var a=tabNavigationContext.getElementById(\"ifIPv4AddressSecondaryMaskRow\");\nvar e=tabNavigationContext.getElementById(\"ifIpAddrAssignMethod-Field\");var c=tabNavigationContext.getElementById(\"ifName-Hidden\");if(d==1||g!=0){h.style.display=\"none\";a.style.display=\"none\"}else{if(f==\"UX2000\"&&c.value!=\"mgmt1\"){if(j==0||(null!=e&&e.value==1)){h.style.display=\"none\";\na.style.display=\"none\"}else{if(b==0){h.style.display=\"none\";a.style.display=\"none\"}else{h.style.display=\"\";a.style.display=\"\"}}}if(f==\"UX1000\"){if(c.value!=\"Ethernet 1\"&&c.value!=\"Ethernet 2\"){if(j==0||(null!=e&&e.value==1)){h.style.display=\"none\";\na.style.display=\"none\"}else{if(d==1){h.style.display=\"none\";a.style.display=\"none\"}else{if(b==0){h.style.display=\"none\";a.style.display=\"none\"}else{h.style.display=\"\";a.style.display=\"\"}}}}}}}function setIPv6AddressFields(f,b,d){var e=tabNavigationContext.getElementById(\"ifIPv6AddressPrimaryRow\");\nvar c=tabNavigationContext.getElementById(\"ifIPv6AddressPrimaryPrefixRow\");var a=tabNavigationContext.getElementById(\"ifIPv6FGRow\");if(b==0||d==0){e.style.display=\"none\";c.style.display=\"none\";a.style.display=\"none\"\n}else{e.style.display=\"\";c.style.display=\"\";a.style.display=\"\"}}function setBridgeIDField(b){var a=tabNavigationContext.getElementById(\"ifBridgeGroupIdRow\");if(a){if(