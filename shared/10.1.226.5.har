atechange=function(){if(a.readyState==4){var d=trim(a.responseText);\nif(d.indexOf(\"ErrorWithDetails\")==0){var e=d.indexOf(\";\");d=d.substring(e+1,d.length-1);openModalDialog(\"/cgi/phpUI/error/modalError.php\",500,150)}else{window.location=b+\"&download\"}}};document.MM_returnValue=false;\na.send();return false}function performASMClearEventLog(a,c){var b=new FormData();b.append(\"LogType\",a);performSBAAction(SBAActions.ACTION_ASM_EVENT_LOG_CLEAR,\"\",null,false,c,b)}function setLogLevelAction(e,d,b){var c=new FormData();\nc.append(\"ActionSetLogLevel\",d);var a=\"\";if(d==SBASetLogLevelActionRequest.ACTION_SBA_Set_Log_Level_None){a=\"None\"}else{if(d==SBASetLogLevelActionRequest.ACTION_SBA_Set_Log_Level_Fatal){a=\"Fatal\"}else{if(d==SBASetLogLevelActionRequest.ACTION_SBA_Set_Log_Level_Error){a=\"Error\"\n}else{if(d==SBASetLogLevelActionRequest.ACTION_SBA_Set_Log_Level_Warning){a=\"Warning\"}else{if(d==SBASetLogLevelActionRequest.ACTION_SBA_Set_Log_Level_Information){a=\"Information\"}else{if(d==SBASetLogLevelActionRequest.ACTION_SBA_Set_Log_Level_Debug){a=\"Debug\"\n}else{if(d==SBASetLogLevelActionRequest.ACTION_SBA_Set_Log_Level_Trace){a=\"Trace\"}}}}}}}if(confirm(\"You have selected \"+a+\" option to set log level.\\n Are you sure you want to proceed?\")){openCheckServerDialog(300,85,\"Applying Changes - please wait...\",false);\nperformSBAAction(SBAActions.ACTION_SBADR_SET_LOG_LEVEL,\"\",null,false,e,c)}}function performASMVirtualMachineAction(b,l,j){var d=new FormData();d.append(\"ActionOnVm\",l);if(l==SBAVmActionRequest.ACTION_SBA_VM_StartHyperV){if(AnyChecked(j)){alert(\"No rows must be selected to perform this operation.\");\nreturn false}if(confirm(\"This action will start Hyper-V service on the Host.\\n Are you sure you want to proceed?\")){openCheckServerDialog(300,85,\"Applying Changes - please wait...\",false);performSBAAction(SBAActions.ACTION_ASM_VIRTUAL_MACHINE_ACTION,\"\",null,false,b,d);\nreturn false}return}if(l==SBAVmActionRequest.ACTION_SBA_VM_StopHyperV){if(AnyChecked(j)){alert(\"No rows must be selected to perform this operation.\");return false}if(confirm(\"This action will stop Hyper-V service on the Host.\\n Are you sure you want to proceed?\")){openCheckServerDialog(300,85,\"Applying Changes - please wait...\",false);\nperformSBAAction(SBAActions.ACTION_ASM_VIRTUAL_MACHINE_ACTION,\"\",null,false,b,d);return false}return}else{if(!AnyChecked(j)){alert(\"No rows in current selection.\\nOne or more rows must be selected to perform this operation.\");\nreturn false}}var k=j.elements.length;var e=\"\";var m=\"\";for(var g=0;g<k;g++){if(j.elements[g].name.indexOf(\"_id_\")!=-1&&j.elements[g].checked){var h=j.elements[g].value;var c=h.split(\"|\");if(c.length==2){e+=c[0]+\",\";\nm+=c[0]+\"|\"}}}if(e!=\"\"){e=e.substr(0,e.length-1)}if(m!=\"\"){m=m.substr(0,m.length-1)}var a=\"\";if(l==SBAVmActionRequest.ACTION_SBA_VM_Start){a=\"Start\"}else{if(l==SBAVmActionRequest.ACTION_SBA_VM_TurnOff){a=\"Turn Off\"\n}else{if(l==SBAVmActionRequest.ACTION_SBA_VM_Shutdown){a=\"Shutdown\"}else{if(l==SBAVmActionRequest.ACTION_SBA_VM_Save){a=\"Save\"}else{if(l==SBAVmActionRequest.ACTION_SBA_VM_Pause){a=\"Pause\"}else{if(l==SBAVmActionRequest.ACTION_SBA_VM_Reset){a=\"Reset\"\n}}}}}}d.append(\"VmList\",m);if(confirm(\"This action will \"+a+\" the selected virtual machines.\\n Are you sure you want to proceed?\")){openCheckServerDialog(300,85,\"Applying Changes - please wait...\",false);\nperformSBAAction(SBAActions.ACTION_ASM_VIRTUAL_MACHINE_ACTION,\"\",null,false,b,d)}return false}function performASMAclResetRules(b,a){if(a!=\"Lync\"){a=\"Skype\"}if(confirm(\"This action will do the following:\\n 1. Reset the Windows Firewall to a default state.\\n 2. Any rules required by \"+a+\", or added by applied security templates will be retained.\\n Are you sure you want to proceed?\")){performSBAAction(SBAActions.ACTION_ASM_ACL_RESET,\"\",null,false,b)\n}return false}function openAddASMACLRuleView(a){var b=getNextAvailableID(a);openA