ueRow\");if(b.value==0){a.style.display=\"none\"\n}else{a.style.display=\"\"}}function onRemoveDTLSVersion(){var d=tabNavigationContext.getElementById(\"DTLSVersion-Field\");var b=buildMultiSelectValueString(d);var a=tabNavigationContext.getCurrentContextPrefix()+\"ClientCipherSequence-Field\";\nvar c=$uxDocQuery(\"#\"+a);c.html(\"\");if(b==\"1.0\"){$uxDocQuery(\"#\"+tabNavigationContext.getCurrentContextPrefix()+\"ClientCipherSequence-Field\").append('<option value=\"1\">TLS_RSA_WITH_AES256_CBC_SHA</option>');\n$uxDocQuery(\"#\"+tabNavigationContext.getCurrentContextPrefix()+\"ClientCipherSequence-Field\").append('<option value=\"0\">TLS_RSA_WITH_AES128_CBC_SHA</option>')}else{$uxDocQuery(\"#\"+tabNavigationContext.getCurrentContextPrefix()+\"ClientCipherSequence-Field\").append('<option value=\"10\">TLS_ECDHE_RSA_WITH_AES_256_GCM_SHA384</option>');\n$uxDocQuery(\"#\"+tabNavigationContext.getCurrentContextPrefix()+\"ClientCipherSequence-Field\").append('<option value=\"9\">TLS_ECDHE_RSA_WITH_AES_128_GCM_SHA256</option>');$uxDocQuery(\"#\"+tabNavigationContext.getCurrentContextPrefix()+\"ClientCipherSequence-Field\").append('<option value=\"6\">TLS_ECDHE_RSA_WITH_AES_256_CBC_SHA384</option>');\n$uxDocQuery(\"#\"+tabNavigationContext.getCurrentContextPrefix()+\"ClientCipherSequence-Field\").append('<option value=\"5\">TLS_ECDHE_RSA_WITH_AES_128_CBC_SHA256</option>');$uxDocQuery(\"#\"+tabNavigationContext.getCurrentContextPrefix()+\"ClientCipherSequence-Field\").append('<option value=\"4\">TLS_RSA_WITH_AES_256_CBC_SHA256</option>');\n$uxDocQuery(\"#\"+tabNavigationContext.getCurrentContextPrefix()+\"ClientCipherSequence-Field\").append('<option value=\"3\">TLS_RSA_WITH_AES_128_CBC_SHA256</option>');$uxDocQuery(\"#\"+tabNavigationContext.getCurrentContextPrefix()+\"ClientCipherSequence-Field\").append('<option value=\"1\">TLS_RSA_WITH_AES256_CBC_SHA</option>');\n$uxDocQuery(\"#\"+tabNavigationContext.getCurrentContextPrefix()+\"ClientCipherSequence-Field\").append('<op